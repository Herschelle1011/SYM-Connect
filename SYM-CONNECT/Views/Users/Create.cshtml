@model SYM_CONNECT.Models.Users
@{
    ViewData["Title"] = "Create";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Create User</h2>
        <p class="text-muted mb-0">Fill out the form below to add a new user account.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-person-plus-fill text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">User Information</h5>
                    <small class="text-muted">Fields marked with <span class="text-danger">*</span> are required</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 rounded-3" role="alert"></div>

                <div class="row g-3">

                    <!-- Full Name -->
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>Full Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FullName" class="form-control themed-input" placeholder="Enter full name" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label field-label">
                            <i class="bi bi-envelope me-1 text-muted"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email" type="email" id="emailInput"
                                 class="form-control themed-input" placeholder="Enter email address" />

                        <span id="emailError"
                              class="text-danger small"
                              style="display:none;">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            This email is already taken.
                        </span>

                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="col-md-6">
                        <label asp-for="PasswordHash" class="form-label field-label">
                            <i class="bi bi-lock me-1 text-muted"></i>
                            Password <span class="text-danger">*</span>
                        </label>

                        <div class="input-group">
                            <input name="PasswordHash"
                                   id="createPassword"
                                   type="password"
                                   class="form-control themed-input"
                                   placeholder="Enter password"
                                   value="@(ViewBag.GeneratedPassword ?? string.Empty)" />

                            <button class="btn"
                                    type="button"
                                    onclick="togglePassword()"
                                    style="border:1.5px solid var(--teal-mid);
                       border-left:none;
                       background:#f7fdfe;
                       color:var(--text-muted);">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>

                        <input type="hidden" name="generate" id="generateFlag" value="false" />


                        <!-- Generate  -->
                        <button type="submit"
                                formnovalidate
                                onclick="document.getElementById('generateFlag').value='true';"
                                style="margin-top:8px;
               display:inline-flex;
               align-items:center;
               gap:5px;
               background:var(--teal-light);
               color:var(--teal-dark);
               border:1.5px solid var(--teal-mid);
               border-radius:8px;
               padding:5px 14px;
               font-size:.78rem;
               font-weight:600;
               cursor:pointer;">
                            <i class="bi bi-magic"></i> Generate Password
                        </button>

                        <!-- Generated password display -->
                        @if (TempData["GeneratedPassword"] != null)
                        {
                            <div style="margin-top:8px;
                        padding:8px 12px;
                        background:var(--teal-light);
                        border:1px solid var(--teal-mid);
                        border-radius:8px;
                        font-size:.78rem;
                        color:var(--teal-dark);
                        font-weight:600;">
                                <i class="bi bi-check-circle me-1"></i>
                                Generated: @TempData["GeneratedPassword"]
                                <small style="color:var(--text-muted);
                              font-weight:400;
                              margin-left:6px;">
                                    (copy this before submitting)
                                </small>
                            </div>
                        }

                        <span asp-validation-for="PasswordHash"
                              class="text-danger small"></span>
                    </div>

                    <!-- Joined Date -->
                    <div class="col-md-6">
                        <label asp-for="CreatedAt" class="form-label field-label">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>Joined Date
                        </label>
                        <input asp-for="CreatedAt"
                               type="datetime-local"
                               class="form-control themed-input"
                               readonly
                               style="background:#f0f9fa;
                  color:var(--text-muted);
                  cursor:not-allowed;" />
                        <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                    </div>

                    <!-- Role -->
                    <div class="col-md-6">
                        <label asp-for="Role" class="form-label field-label">
                            <i class="bi bi-shield-check me-1 text-muted"></i>Role <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Role" class="form-select themed-input">
                            <option value="" disabled selected>-- Select Role --</option>
                            <option value="Leader">Leader</option>
                            <option value="Member">Member</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>



                    <!-- Status -->
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-circle-half me-1 text-muted"></i>Status (default to Active)<span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-3 pt-1">
                            <div class="form-check themed-radio">

                                <input class="form-check-input" type="radio" asp-for="Status" checked
                                       value="Active" id="statusActive" />

                                <label class="form-check-label" for="statusActive">
                                    <span class="radio-badge badge-approved">Active</span>
                                </label>
                            </div>
                            @* <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="Status"
                                       value="Inactive" id="statusInactive" />
                                <label class="form-check-label" for="statusInactive">
                                    <span class="radio-badge badge-rejected">Inactive</span>
                                </label>
                            </div> *@
                        </div>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                </div>

                <hr style="border-color: #e8f7f8;" class="mt-4" />

                <!-- Action Buttons -->
                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-person-plus"></i> Create User
                    </button>

                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ── Toggle Password Visibility ─────────────────
        function togglePassword() {
            var input   = document.getElementById('createPassword');
            var eyeIcon = document.getElementById('eyeIcon');

            if (input.type === 'password') {
                input.type        = 'text';
                eyeIcon.className = 'bi bi-eye-slash';
            } else {
                input.type        = 'password';
                eyeIcon.className = 'bi bi-eye';
            }
        }
    </script>
}