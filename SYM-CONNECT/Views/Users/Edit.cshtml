@model SYM_CONNECT.Models.Users
@{
    ViewData["Title"] = "Edit";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Edit User</h2>
        <p class="text-muted mb-0">Update the details of this user account.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-person-fill text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">User Information</h5>
                    <small class="text-muted">Fields marked with <span class="text-danger">*</span> are required</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <form id="editUserForm" asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 rounded-3" role="alert"></div>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <!-- Full Name -->
                    <!-- First Name -->
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>First Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FirstName" class="form-control themed-input" placeholder="Enter first name" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>Last Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="LastName" class="form-control themed-input" placeholder="Enter last name" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label field-label">
                            <i class="bi bi-envelope me-1 text-muted"></i>Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email" class="form-control themed-input" placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>


                    <!-- Joined Date -->
                    <div class="col-md-6">
                        <label asp-for="CreatedAt" class="form-label field-label">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>Joined Date
                        </label>
                        <input asp-for="CreatedAt"
                               type="datetime-local"
                               class="form-control themed-input"
                               readonly
                               style="background:#f0f9fa;
                  color:var(--text-muted);
                  cursor:not-allowed;" />
                        <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                    </div>

                    <!-- Role -->
                    <div class="col-md-6">
                        <label asp-for="Role" class="form-label field-label">
                            <i class="bi bi-shield-check me-1 text-muted"></i>Role <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Role" class="form-select themed-input">
                            <option value="" disabled>-- Select Role --</option>
                            <option value="Leader">Leader</option>
                            <option value="Member">Member</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-circle-half me-1 text-muted"></i>Status <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-3 pt-1">
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="Status"
                                       value="Active" id="statusActive" />
                                <label class="form-check-label" for="statusActive">
                                    <span class="radio-badge badge-approved">Active</span>
                                </label>
                            </div>
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="Status"
                                       value="Inactive" id="statusInactive" />
                                <label class="form-check-label" for="statusInactive">
                                    <span class="radio-badge badge-rejected">Inactive</span>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                </div>

                <hr style="border-color: #e8f7f8;" class="mt-4" />

         

                <!-- Action Buttons -->
                <div class="d-flex gap-2 pt-2">
                    <button type="button"
                            id="saveChangesBtn"
                            class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-floppy"></i> Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>



<!-- Inactive Confirmation Modal — needed on Edit page -->
<div class="modal fade" id="inactiveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px;
                    border:1px solid var(--teal-light);
                    overflow:hidden;">

            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark);font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Inactive User
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark);font-size:.9rem;">
                    Are you sure you want to set
                </p>
                <p style="color:#e53e3e;font-weight:700;
                           font-size:1rem;margin-top:4px;">
                    "<span id="InactiveUsersName"></span>"
                    to Inactive?
                </p>
                <p style="color:var(--text-muted);font-size:.8rem;
                           margin-top:8px;">
                    This user will lose access to the system.
                </p>
            </div>

            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        background:#fafeff;">
                <button type="button"
                        data-bs-dismiss="modal"
                        style="background:#f1f5f9;
                               color:var(--text-dark);
                               border:1px solid #cdd6df;
                               border-radius:8px;padding:7px 18px;
                               font-size:.83rem;font-weight:600;
                               cursor:pointer;">
                    Go Back
                </button>
                <form id="inactiveForm" method="post"
                      style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="background:#f59e0b;color:#fff;
                                   border:none;border-radius:8px;
                                   padding:7px 18px;font-size:.83rem;
                                   font-weight:600;cursor:pointer;">
                        <i class="bi bi-x-circle me-1"></i>
                        Yes, Set Inactive
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>
    document.getElementById('saveChangesBtn')
        .addEventListener('click', function () {

        var inactiveSelected = document
            .getElementById('statusInactive').checked;

        if (inactiveSelected) {
            //Show modal BEFORE submits
            openInactiveModal(@Model.Id, '@Model.Email');
        } else {
            document.getElementById('editUserForm').submit();
        }
    });
</script>