@model SYM_CONNECT.Models.Users
@{
    ViewData["Title"] = "Details";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">User Details</h2>
        <p class="text-muted mb-0">Viewing detailed information for this user account.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-person-lines-fill text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">User Information</h5>
                    <small class="text-muted">Read-only view of user account details</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <div class="row g-3">

                <!-- Full Name -->
                <div class="col-md-6">
                    <label class="form-label field-label">
                        <i class="bi bi-person me-1 text-muted"></i>
                        @Html.DisplayNameFor(model => model.FullName)
                    </label>
                    <div class="form-control themed-input bg-light" style="color:#444;">
                        @Html.DisplayFor(model => model.FullName)
                    </div>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                    <label class="form-label field-label">
                        <i class="bi bi-envelope me-1 text-muted"></i>
                        @Html.DisplayNameFor(model => model.Email)
                    </label>
                    <div class="form-control themed-input bg-light" style="color:#444;">
                        @Html.DisplayFor(model => model.Email)
                    </div>
                </div>

                <!-- Joined Date -->
                <div class="col-md-6">
                    <label class="form-label field-label">
                        <i class="bi bi-calendar3 me-1 text-muted"></i>
                        @Html.DisplayNameFor(model => model.CreatedAt)
                    </label>
                    <div class="form-control themed-input bg-light" style="color:#444;">
                        @Model.CreatedAt.ToString("dd MMMM yyyy, h:mm tt")
                    </div>
                </div>

                <!-- Role -->
                <div class="col-md-6">
                    <label class="form-label field-label">
                        <i class="bi bi-shield-check me-1 text-muted"></i>
                        @Html.DisplayNameFor(model => model.Role)
                    </label>
                    <div class="form-control themed-input bg-light" style="color:#444;">
                        @Html.DisplayFor(model => model.Role)
                    </div>
                </div>

                <!-- Status -->
                <div class="col-md-6">
                    <label class="form-label field-label">
                        <i class="bi bi-circle-half me-1 text-muted"></i>
                        @Html.DisplayNameFor(model => model.Status)
                    </label>
                    <div class="pt-1">
                        @if (Model.Status == "Active")
                        {
                            <span class="badge-active">Active</span>
                        }
                        else if (Model.Status == "Inactive")
                        {
                            <span class="badge-inactive">Inactive</span>
                        }
                        else
                        {
                            <span class="badge-pending">@Model.Status</span>
                        }
                    </div>
                </div>

            </div>

            <hr style="border-color: #e8f7f8;" class="mt-4" />

            <!-- Action Buttons -->
            <div class="d-flex gap-2 pt-2">
                <a asp-action="Edit" asp-route-id="@Model?.Id"
                   class="btn btn-save d-flex align-items-center gap-1">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index"
                   class="btn btn-back d-flex align-items-center gap-1">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>

        </div>
    </div>
</div>