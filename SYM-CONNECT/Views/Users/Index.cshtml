@model IEnumerable<SYM_CONNECT.Models.Users>
@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="mb-2">
    <h1 class="page-title">User Management</h1>
    <p class="page-subtitle">Manage your team members and their account permissions here.</p>
</div>

<!-- Card / Table -->
<div class="card-table">

    <!-- Toolbar -->
    <div class="toolbar">

        <!-- Role Filter Dropdown -->
        <div style="position:relative; display:inline-block;">

            <!-- Trigger Button -->
            <button class="btn-role-filter"
                    id="roleFilterBtn"
                    onclick="toggleRoleDropdown()"
                    type="button">
                <i class="bi bi-funnel-fill"></i>
                <span id="roleFilterLabel">Role</span>
                <i class="bi bi-chevron-down"
                   style="font-size:.65rem;opacity:.6;"></i>
            </button>

            <!-- Dropdown Menu -->
            <div id="roleDropdown"
                 style="display:none;
                position:absolute;
                top:calc(100% + 6px);
                left:0;
                background:#fff;
                border:1px solid #d1f0e8;
                border-radius:10px;
                box-shadow:0 4px 16px rgba(10,181,196,.12);
                min-width:150px;
                z-index:999;
                overflow:hidden;">

                <!-- Each option -->
                <div onclick="applyRoleFilter('All')"
                     class="role-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-people"></i> All
                </div>
                <div onclick="applyRoleFilter('Admin')"
                     class="role-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-shield-check"></i> Admin
                </div>
                <div onclick="applyRoleFilter('Leader')"
                     class="role-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-person-badge"></i> Leader
                </div>
                <div onclick="applyRoleFilter('Member')"
                     class="role-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;">
                    <i class="bi bi-person"></i> Member
                </div>

            </div>


        </div>



        <!-- Search -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search" id="searchInput" oninput="filterTable()" />
        </div>

        <!-- Archive -->
        <button class="btn-archive-outline"  data-bs-toggle="modal"
                data-bs-target="#inactiveUsers">
            <i class="bi bi-archive"></i> Inactive Users
        </button>



        <!-- Export -->
        <a asp-action="ExportPDF"
           asp-controller="Users"
           class="btn-export">
            <i class="bi bi-upload"></i> Export as PDF
        </a>

        <!-- Add User -->
        <a asp-action="Create" class="btn-add-user" style="text-decoration:none;">
            <i class="bi bi-plus-circle-fill"></i> Add User
        </a>

    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
        <table class="user-table" id="userTable">
            <thead>
                <tr>
                    <th><i class="bi bi-person"></i> Full Name</th>
                    <th><i class="bi bi-envelope"></i> Email</th>
                    <th><i class="bi bi-shield-check"></i> Role</th>
                    <th><i class="bi bi-circle-half"></i> Status</th>
                    <th><i class="bi bi-calendar3"></i> Joined Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var item in Model)
                {
                    if(item.Status == "Active")
                    {
                    <tr>
                        <td>
                            <span class="user-name-cell">
                                <img src="https://i.pravatar.cc/40?u=@item.Id" alt="" class="user-avatar" />
                                @Html.DisplayFor(modelItem => item.FullName)
                            </span>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.Role)</td>
                        <td>
                            @{
                                var status = item.Status?.ToString() ?? "";
                            }
                            @if (status == "Active")
                            {
                                <span class="badge-active">Active</span>
                            }
                            else if (status == "Inactive")
                            {
                                <span class="badge-inactive">Inactive</span>
                            }
                            else
                            {
                                <span class="badge-pending">@status</span>
                            }
                        </td>
                        <td>@item.CreatedAt.ToString("dd MMMM yyyy, h:mm tt")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn-action btn-edit" style="text-decoration:none;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn-action btn-arc ms-1" style="text-decoration:none;">
                                <i class="bi bi-eye"></i> Details
                            </a>

                                <button onclick="openInactiveModal(@item.Id, '@item.Email')"  class="btn-action ms-1" style="text-decoration:none; color:#e74c3c; border-color:#f5c0b8; background:#fff5f5; border-radius:7px; padding:5px 12px; font-size:.75rem; font-weight:500; display:inline-flex; align-items:center; gap:4px;">
                                <i class="bi bi-dash-square"></i> Inactive
                            </button>

                        </td>
                    </tr>
                    }

                
                }

                <tr id="noSearchResults" style="display:none;">
                    <td colspan="6"
                        style="text-align:center;padding:20px;
                       color:#888;font-size:13px;">
                        <i class="bi bi-search me-1"></i>
                        No users found matching your search.
                    </td>
                </tr>


            </tbody>
        </table>
    </div>

    <!-- Footer / Pagination -->
    <div class="table-footer">
        <div class="rows-info">
            Rows per page
            <select>
                <option>05</option>
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
            &nbsp; 1–5 of @Model.Count() rows
        </div>

        <div class="pagination-btns">
            <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
            <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
            <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
            <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
        </div>
    </div>

</div><!-- /.card-table -->



<!-- Inactive Confirmation Modal -->
<div class="modal fade" id="inactiveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px; border:1px solid var(--teal-light);
                    overflow:hidden;">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark); font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Inactive User
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark); font-size:.9rem;">
                    Are you sure you want to Inactive this user?
                </p>

                <p style="color:#e53e3e; font-weight:700;
                           font-size:1rem; margin-top:4px;">
                    "<span id="InactiveUsersName"></span>"?
                </p>

                <p style="color:var(--text-muted); font-size:.8rem;
                           margin-top:8px;">
                    This user will lose access to the system.
                </p>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        background:#fafeff;">

                <!-- Go Back -->
                <button type="button" data-bs-dismiss="modal"
                        style="background:#f1f5f9; color:var(--text-dark);
                               border:1px solid #cdd6df; border-radius:8px;
                               padding:7px 18px; font-size:.83rem;
                               font-weight:600; cursor:pointer;">
                    Go Back
                </button>

                <!-- ✅ form with unique id — cancelForm -->
                <form id="inactiveForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="background:#f59e0b; color:#fff;
                                   border:none; border-radius:8px;
                                   padding:7px 18px; font-size:.83rem;
                                   font-weight:600; cursor:pointer;">
                        <i class="bi bi-x-circle me-1"></i> Yes, Inactive It
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>



<!-- ── INACTIVE USERS MODAL ────────────────────────────── -->
<div class="modal fade" id="inactiveUsers" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content"
             style="border-radius:14px;overflow:hidden;
                    border:1px solid var(--teal-light);
                    box-shadow:0 8px 32px rgba(10,181,196,.15);">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);
                        padding:14px 20px;flex-direction:column;
                        align-items:stretch;gap:10px;">

                <!-- Title row -->
                <div class="d-flex align-items-center
                            justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-archive"
                           style="color:var(--teal-dark);
                                  font-size:15px;"></i>
                        <h5 class="modal-title mb-0"
                            style="font-size:15px;font-weight:700;
                                   color:var(--teal-dark);">
                            Inactive Users
                        </h5>
                        <span style="background:#e53e3e;color:#fff;
                                     font-size:11px;font-weight:700;
                                     padding:2px 8px;
                                     border-radius:12px;">
                            @{
                                 var inactiveUsers = Model.Count(u => u.Status == "Inactive"); //count users inactive
                            }

                            @inactiveUsers

                        </span>
                    </div>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <!-- Search bar -->
                <div style="position:relative;">
                    <i class="bi bi-search"
                       style="position:absolute;left:10px;top:50%;
                              transform:translateY(-50%);
                              color:var(--teal-dark);
                              font-size:12px;"></i>
                    <input type="text"
                           id="cancelSearch"
                           placeholder="Search inactive users..."   
                           oninput="filterCancelledRows(this.value)"
                           style="width:100%;box-sizing:border-box;
                                  padding:7px 12px 7px 30px;
                                  border:1px solid var(--teal-mid);
                                  border-radius:8px;font-size:13px;
                                  background:#f0fbf7;
                                  color:var(--teal-dark);outline:none;">
                </div>
            </div>

            <!-- LEGEND -->
            <div style="display:flex;gap:20px;padding:9px 20px;
                        border-bottom:1px solid var(--teal-light);
                        background:#f5fbfd;">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:9px;height:9px;border-radius:50%;
                                background:#22c55e;flex-shrink:0;">
                    </div>
                    <small style="color:var(--text-muted);font-weight:500;">
                        Reactivate — restore an account
                    </small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div style="width:9px;height:9px;border-radius:50%;
                                background:#ef4444;flex-shrink:0;">
                    </div>
                    <small style="color:var(--text-muted);font-weight:500;">
                        Delete — permanent delete account
                    </small>
                </div>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:12px 16px;">
              
                @if (inactiveUsers == 0)
                              
                {
                    <p class="text-muted text-center py-3">
                        No Inactive Users found.
                    </p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2"
                         id="cancelledEventList">

                        @{
                            var inactiveAllUsers = Model.Where(u => u.Status == "Inactive").ToList();
                        }

                        @foreach (var ev in inactiveAllUsers)
                        {
                            <div class="cancelled-row"
                                 data-title="@ev.Email.ToLower()"
                                 style="display:flex;align-items:center;
                                                        justify-content:space-between;
                                                        padding:11px 14px;
                                                        border:1px solid var(--teal-mid);
                                                        border-radius:10px;
                                                        background:var(--teal-light);
                                                        gap:10px;">

                                <!-- Left: info -->
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13.5px;
                                                                font-weight:700;
                                                                color:var(--teal-dark);
                                                                white-space:nowrap;
                                                                overflow:hidden;
                                                                text-overflow:ellipsis;">
                                        @ev.Email
                                    </div>

                                    <!-- User Joined date -->
                                    <div class="d-flex align-items-center
                                                                gap-1 mt-1">
                                        <i class="bi bi-calendar3"
                                           style="font-size:10px;
                                                                  color:var(--teal-dark);">
                                        </i>
                                        <span style="font-size:11px;
                                                                     color:var(--teal-dark);
                                                                     font-weight:500;">
                                            Joined Date:
                                            @ev.CreatedAt.ToString("M/d/yyyy h:mm:ss tt")
                                        </span>
                                    </div>

                                    <!-- Cancelled date -->
                                    <div class="d-flex align-items-center
                                                                gap-1 mt-1">
                                        <i class="bi bi-clock-history"
                                           style="font-size:10px;
                                                                  color:#e53e3e;">
                                        </i>
                                        <span style="font-size:11px;
                                                                     color:#e53e3e;
                                                                     font-weight:500;">
                                            Last Active:
                                            @(ev.InactiveAt.HasValue
                                                                                ? ev.InactiveAt.Value
                                                                                .ToString("MMM dd, yyyy h:mm tt")
                                                                                : "Date not recorded")

                                        </span>
                                    </div>
                                </div>

                                <!-- Right: buttons -->
                                <div class="d-flex align-items-center
                                                            gap-2 flex-shrink-0">

                                    <!-- Reactivate -->
                                    <form asp-action="Restored"
                                          asp-route-id="@ev.Id"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                title="Reactivate"
                                                style="width:33px;height:33px;
                                                                       border-radius:8px;
                                                                       background:#16a34a;
                                                                       border:none;
                                                                       cursor:pointer;
                                                                       display:flex;
                                                                       align-items:center;
                                                                       justify-content:center;">
                                            <i class="bi bi-arrow-counterclockwise"
                                               style="color:#fff;
                                                                      font-size:14px;">
                                            </i>
                                        </button>
                                    </form>

                                    <!-- Delete -->
                                    <button onclick="openDisabledModal(
                                                                @ev.Id,
                                                                '@Html.Raw(ev.Email
                                                                                                                                            .Replace("'", "\\'"))')"
                                    style="display:flex;
                                                   align-items:center;
                                                   gap:5px;
                                                   padding:7px 13px;
                                                   background:#ef4444;
                                                   color:#fff;border:none;
                                                   border-radius:8px;
                                                   font-size:12px;
                                                   font-weight:600;
                                                   cursor:pointer;">
                                <i class="bi bi-trash"
                                   style="font-size:12px;"></i>
                                Delete
                            </button>
                        </div>
                    </div>
                                        }

                        <!-- No search results -->
                        <p id="noCancelResults"
                           style="display:none;text-align:center;
                                          font-size:13px;color:#888;
                                          padding:16px 0;margin:0;">
                            No inactive users match your search.
                        </p>
                    </div>
                }
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        padding:11px 20px;background:#fafeff;">
                <button type="button"
                        data-bs-dismiss="modal"
                        style="background:#5f6b7a;color:#fff;
                               border:none;padding:7px 20px;
                               border-radius:8px;font-size:13px;
                               font-weight:600;cursor:pointer;">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>


<!-- Delete Confirmation Modal -->
<div class="modal fade" id="disabledModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px; border:2px solid var(--teal-dark);
                    overflow:hidden;">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark); font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Delete
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark); font-size:.9rem;">
                    Are you sure you want to delete this account?
                </p>

                <!-- THIS IS WHERE THE TITLE WILL APPEAR -->
                <p style="color:#e53e3e; font-weight:700;
                           font-size:1rem; margin-top:4px;">
                    "<span id="disabledUserName"></span>"?
                </p>

                <p style="color:var(--text-muted); font-size:.8rem;
                           margin-top:8px;">
                    This action cannot be undone.
                </p>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        background:#fafeff;">

                <!-- Go Back button -->
                <button type="button"
                        data-bs-dismiss="modal"
                        style="background:#f1f5f9; color:var(--text-dark);
                               border:1px solid #cdd6df; border-radius:8px;
                               padding:7px 18px; font-size:.83rem;
                               font-weight:600; cursor:pointer;">
                    Go Back
                </button>

                <!-- YES confirm button — this submits the form -->
                <form id="disabledForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="background:#ef4444; color:#fff;
                                   border:none; border-radius:8px;
                                   padding:7px 18px; font-size:.83rem;
                                   font-weight:600; cursor:pointer;">
                        <i class="bi bi-trash me-1"></i> Yes, Delete It
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>




