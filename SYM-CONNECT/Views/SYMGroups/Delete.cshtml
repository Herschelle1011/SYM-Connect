@model SYM_CONNECT.Models.SYMGroup
@{
    ViewData["Title"] = "Delete";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #dc3545;">Delete Group</h2>
        <p class="text-muted mb-0">Please review the details before confirming deletion.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#dc3545,#a71d2a);">
                    <i class="bi bi-trash-fill text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Group Information</h5>
                    <small class="text-muted">Are you sure you want to delete this group?</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <!-- Details -->
            <div class="row g-3 mb-4">

                <!-- Name -->
                <div class="col-md-6">
                    <div class="p-3 rounded-3" style="background:#f8f9fa;">
                        <div style="font-size:.72rem; color:#90adb8; text-transform:uppercase; letter-spacing:.05em;">
                            <i class="bi bi-tag me-1"></i>Name
                        </div>
                        <div class="fw-semibold mt-1" style="font-size:.95rem;">
                            @Html.DisplayFor(model => model.Name)
                        </div>
                    </div>
                </div>

                <!-- Leader -->
                <div class="col-md-6">
                    <div class="p-3 rounded-3" style="background:#f8f9fa;">
                        <div style="font-size:.72rem; color:#90adb8; text-transform:uppercase; letter-spacing:.05em;">
                            <i class="bi bi-person me-1"></i>Leader
                        </div>
                        <div class="fw-semibold mt-1" style="font-size:.95rem;">
                            @Html.DisplayFor(model => model.Leader.Email)
                        </div>
                    </div>
                </div>

                <!-- Region -->
                <div class="col-md-6">
                    <div class="p-3 rounded-3" style="background:#f8f9fa;">
                        <div style="font-size:.72rem; color:#90adb8; text-transform:uppercase; letter-spacing:.05em;">
                            <i class="bi bi-geo-alt me-1"></i>Region
                        </div>
                        <div class="fw-semibold mt-1" style="font-size:.95rem;">
                            @Html.DisplayFor(model => model.Region)
                        </div>
                    </div>
                </div>

                <!-- Sub Region -->
                <div class="col-md-6">
                    <div class="p-3 rounded-3" style="background:#f8f9fa;">
                        <div style="font-size:.72rem; color:#90adb8; text-transform:uppercase; letter-spacing:.05em;">
                            <i class="bi bi-geo me-1"></i>Sub Region
                        </div>
                        <div class="fw-semibold mt-1" style="font-size:.95rem;">
                            @Html.DisplayFor(model => model.SubRegion)
                        </div>
                    </div>
                </div>

                <!-- Status -->
                <div class="col-md-6">
                    <div class="p-3 rounded-3" style="background:#f8f9fa;">
                        <div style="font-size:.72rem; color:#90adb8; text-transform:uppercase; letter-spacing:.05em;">
                            <i class="bi bi-shield-check me-1"></i>Status
                        </div>
                        <div class="mt-1">
                            @if (Model.Status == "Active")
                            {
                                <span class="badge-active">+ Active</span>
                            }
                            else
                            {
                                <span class="badge-inactive">+ Inactive</span>
                            }
                        </div>
                    </div>
                </div>

            </div>

            <hr style="border-color: #e8f7f8;" />

            <!-- Action Buttons -->
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="GroupId" />
                <div class="d-flex gap-2 pt-2">
                    <button type="submit"
                            class="btn d-flex align-items-center gap-1"
                            style="background:#dc3545; color:#fff; border-radius:8px;">
                        <i class="bi bi-trash-fill"></i> Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>