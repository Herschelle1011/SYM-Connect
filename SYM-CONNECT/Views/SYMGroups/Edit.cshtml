@model SYM_CONNECT.Models.SYMGroup
@{
    ViewData["Title"] = "Edit";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Edit Group</h2>
        <p class="text-muted mb-0">Update the details of this group.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-pencil-square text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Group Information</h5>
                    <small class="text-muted">Fields marked with <span class="text-danger">*</span> are required</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <form asp-action="Edit" id="editGroupForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 rounded-3" role="alert"></div>
                <input type="hidden" asp-for="GroupId" />

                <div class="row g-3">

                    <!-- Name -->
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label field-label">
                            <i class="bi bi-tag me-1 text-muted"></i>Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control themed-input" placeholder="Enter group name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <!-- Leader -->
                    <div class="col-md-6">
                        <label asp-for="LeaderId" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>Leader <span class="text-danger">*</span>
                        </label>
                        <select asp-for="LeaderId" class="form-select themed-input"
                                asp-items="ViewBag.LeaderId">
                            <option value="">-- Select Leader --</option>
                        </select>
                        <span asp-validation-for="LeaderId" class="text-danger small"></span>
                    </div>

                    <!-- Region -->
                    <div class="col-md-6">
                        <label asp-for="Region" class="form-label field-label">
                            <i class="bi bi-geo-alt me-1 text-muted"></i>Region <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Region" class="form-control themed-input" placeholder="Enter region" />
                        <span asp-validation-for="Region" class="text-danger small"></span>
                    </div>

                    <!-- Sub Region -->
                    <div class="col-md-6">
                        <label asp-for="SubRegion" class="form-label field-label">
                            <i class="bi bi-geo me-1 text-muted"></i>Sub Region <span class="text-danger">*</span>
                        </label>
                        <input asp-for="SubRegion" class="form-control themed-input" placeholder="Enter sub region" />
                        <span asp-validation-for="SubRegion" class="text-danger small"></span>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-shield-check me-1 text-muted"></i>Status <span class="text-danger">*</span>
                        </label>
                        <div class="d-flex gap-3 pt-1">
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Active" id="statusActive" />
                                <label class="form-check-label" for="statusActive">
                                    <span class="radio-badge badge-approved">Active</span>
                                </label>
                            </div>

                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="Status" value="Inactive" id="statusInactive" />
                                <label class="form-check-label" for="statusInactive">
                                    <span class="radio-badge badge-rejected">Inactive</span>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                </div>

                <hr style="border-color: #e8f7f8;" class="mt-4" />

                <div class="d-flex gap-2 pt-2">
                    <button type="button" id="saveChangesBtn"
                            class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-floppy"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- Inactive Confirmation Modal — needed on Edit page -->
<div class="modal fade" id="inactiveGroupModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px;
                    border:1px solid var(--teal-light);
                    overflow:hidden;">

            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark);font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Inactive Group
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark);font-size:.9rem;">
                    Are you sure you want to set
                </p>
                <p style="color:#e53e3e;font-weight:700;
                           font-size:1rem;margin-top:4px;">
                    "<span id="InactiveGroupName"></span>"
                    to Inactive?
                </p>
                <p style="color:var(--text-muted);font-size:.8rem;
                           margin-top:8px;">
                    This Group will lose members.
                </p>
            </div>

            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);background:#fafeff;">
                <button type="button"
                        data-bs-dismiss="modal"
                        style="background:#f1f5f9;color:var(--text-dark);
                   border:1px solid #cdd6df;border-radius:8px;
                   padding:7px 18px;font-size:.83rem;
                   font-weight:600;cursor:pointer;">
                    Go Back
                </button>
                <button type="button"
                        id="confirmInactiveBtn"
                        style="background:#f59e0b;color:#fff;border:none;
                   border-radius:8px;padding:7px 18px;
                   font-size:.83rem;font-weight:600;cursor:pointer;">
                    <i class="bi bi-x-circle me-1"></i> Yes, Set Inactive
                </button>
            </div>
           </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <script>
            // SAVE BUTTON — INTERCEPT IF INACTIVE IS SELECTED
                document.getElementById('saveChangesBtn')
                    .addEventListener('click', function () {
                        var inactiveSelected = document
                            .getElementById('statusInactive').checked;

                        if (inactiveSelected) {
                            // SHOW MODAL — DON'T SUBMIT YET
                            document.getElementById('InactiveGroupName')
                                .innerText = '@Model.Name';

                            var modal = new bootstrap.Modal(
                                document.getElementById('inactiveGroupModal')
                            );
                            modal.show();
                        } else {
                            // SUBMIT FORM DIRECTLY
                            document.getElementById('editGroupForm').submit();
                        }
                    });

                // CONFIRM BUTTON INSIDE MODAL — NOW ACTUALLY SUBMIT THE FORM
                document.getElementById('confirmInactiveBtn')
                    .addEventListener('click', function () {
                        // MAKE SURE INACTIVE RADIO IS CHECKED
                        document.getElementById('statusInactive').checked = true;

                        // SUBMIT THE MAIN FORM
                        document.getElementById('editGroupForm').submit();
                    });
        </script>
    }
}