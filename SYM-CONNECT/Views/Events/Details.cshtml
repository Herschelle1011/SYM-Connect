@model SYM_CONNECT.Models.Event
@{
    ViewData["Title"] = "Details";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Event Details</h2>
        <p class="text-muted mb-0">View the full information of this event.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="d-flex align-items-center gap-2">
                    <span class="rounded-3 d-flex align-items-center justify-content-center"
                          style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                        <i class="bi bi-calendar-event text-white fs-5"></i>
                    </span>
                    <div>
                        <h5 class="mb-0 fw-bold text-dark">@Html.DisplayFor(model => model.Title)</h5>
                        <small class="text-muted">Event Information</small>
                    </div>
                </div>

                <!-- Approval Status Badge -->
                @{
                    var status = Model?.ApprovalStatus?.ToString();
                    var badgeClass = status == "Approved" ? "badge-approved"
                    : status == "Pending" ? "badge-pending"
                    : "badge-inactive";
                }
                <span class="status-badge @badgeClass">@status</span>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <!-- Detail Rows -->
            <dl class="row gy-3 mb-0">

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-tag me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.Title)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.Title)
                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-text-left me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.Description)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.Description)
                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-calendar3 me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.EventDate)
                </dt>

                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.EventDate)


                    @{
                        if (Model.ApprovalStatus == "Approved")
                        {
                            if (Model.EventDate > DateTime.Now)
                            {
                                <span class="badge-upcoming ms-2">
                                    <i class="bi bi-clock me-1"></i>Upcoming
                                </span>
                            }

                            else if (Model.EventDate == DateTime.Now)
                            {
                                <span class="badge-active ms-2">
                                    <i class="bi bi-circle-fill me-1" style="font-size:7px;"></i>Ongoing
                                </span>
                            }
                            else
                            {
                                <span class="badge-done ms-2">
                                    <i class="bi bi-check-circle me-1"></i>Done
                                </span>
                            }
                        }

                    }

                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-calendar3 me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.EndDate)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.EndDate)
                </dd>


                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-shield-check me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.ApprovalStatus)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    <span class="status-badge @badgeClass">@status</span>
                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-person me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.CreatedByUser)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.CreatedByUser.Email)
                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-person-check me-1 text-muted"></i>
                    @Html.DisplayNameFor(model => model.ApprovedByUser)
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @Html.DisplayFor(model => model.ApprovedByUser.Email)
                </dd>

                <dt class="col-sm-3 col-lg-2 detail-label">
                    <i class="bi bi-person-badge me-1 text-muted"></i>
                    Assigned Groups
                </dt>
                <dd class="col-sm-9 col-lg-10 detail-value">
                    @if (Model.AssignedGroups != null && Model.AssignedGroups.Any())
                    {
                        @foreach (var group in Model.AssignedGroups)
                        {
                            <span class="badge rounded-pill"
                                  style="background:#e1f5ee; color:#085041;
                                 font-size:13px; padding:5px 12px;
                                 margin-right:4px; margin-bottom:4px;
                                 display:inline-block;">
                                @group.Name — @(group.Leader?.FullName ?? "No Leader")
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No groups assigned</span>
                    }
                </dd>

            </dl>

            <hr style="border-color: #e8f7f8;" />

            <!-- Action Buttons -->
            <div class="d-flex gap-2 pt-2">
                <a asp-action="Edit" asp-route-id="@Model?.EventId"
                   class="btn btn-sm btn-outline-edit d-flex align-items-center gap-1">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index"
                   class="btn btn-sm btn-back d-flex align-items-center gap-1">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>

        </div>
    </div>
</div>

