@model List<SYM_CONNECT.Models.Event>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
        }

        h2 {
            color: #0ab5c4;
            margin-bottom: 4px;
        }

        p {
            color: #888;
            font-size: 11px;
            margin-top: 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
        }

        thead {
            background: #0ab5c4;
            color: white;
        }

        th {
            padding: 8px 10px;
            text-align: left;
            font-size: 11px;
        }

        td {
            padding: 7px 10px;
            border-bottom: 1px solid #e8f7f8;
            font-size: 11px;
            vertical-align: middle;
        }

        tr:nth-child(even) {
            background: #f5fbfd;
        }

        /* ✅ Fixed badge classes to match ApprovalStatus values */
        .badge-approved {
            background: #d1fae5;
            color: #065f46;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .badge-pending {
            background: #fef3c7;
            color: #92400e;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .badge-rejected {
            background: #fee2e2;
            color: #991b1b;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .badge-done {
            background: #dbeafe;
            color: #1e40af;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .badge-upcoming {
            background: #fef3c7;
            color: #92400e;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .badge-ongoing {
            background: #d1fae5;
            color: #065f46;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
        }

        .footer {
            margin-top: 20px;
            font-size: 10px;
            color: #aaa;
            text-align: right;
        }
    </style>
</head>
<body>

    <h2>SYM Connect — Events List</h2>
    <p>Generated on: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")</p>
    <p>Total Events: @Model.Count</p>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Event Name</th>
                <th>Description</th>
                <th>Event Date</th>
                <th>Progress</th>
                <th>Created By</th>
                <th>Approved By</th>
                <th>Approval Status</th>
                <th>Groups</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var ev = Model[i];

                @* Approval status badge *@
                var approvalClass = ev.ApprovalStatus == "Approved" ? "badge-approved"
                : ev.ApprovalStatus == "Pending" ? "badge-pending"
                : "badge-rejected";

                @* Date progress badge *@
                var now = DateTime.Now;
                var isToday = ev.EventDate.Date == now.Date;
                var isPast = ev.EventDate < now && !isToday;
                var progressClass = isToday ? "badge-ongoing"
                : isPast ? "badge-done"
                : "badge-upcoming";
                var progressLabel = isToday ? "Ongoing"
                : isPast ? "Done"
                : "Upcoming";

                <tr>
                    <td>@(i + 1)</td>
                    <td>@ev.Title</td>
                    <td>@ev.Description</td>

                    @* Formatted date *@
                    <td>@ev.EventDate.ToString("MMM dd, yyyy hh:mm tt")</td>

                    @* Progress badge *@
                    <td><span class="@progressClass">@progressLabel</span></td>

                    @* Show email not object *@
                    <td>@(ev.CreatedByUser?.Email ?? "—")</td>
                    <td>@(ev.ApprovedByUser?.Email ?? "—")</td>

                    @* Approval badge *@
                    <td><span class="@approvalClass">@ev.ApprovalStatus</span></td>


                    <td>
                        @if (ev.AssignedGroups != null && ev.AssignedGroups.Any())
                        {
                            @string.Join(", ", ev.AssignedGroups.Select(g => g.Name))
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                </tr>

          
            }
        </tbody>
    </table>

    <div class="footer">
        SYM Connect System — Confidential
    </div>

</body>
</html>