@model IEnumerable<SYM_CONNECT.Models.Event>

@{
    ViewData["Title"] = "Event Management";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="mb-2">
    <h1 class="page-title">Event Management</h1>
    <p class="page-subtitle">Manage your events and their approval status here.</p>
</div>

<!-- Card / Table -->
<div class="card-table">

    <!-- Toolbar -->
    <div class="toolbar">

        <!-- Status filter -->
        <button class="btn-role-filter">
            <i class="bi bi-funnel-fill"></i> Status
            <i class="bi bi-chevron-down" style="font-size:.65rem;opacity:.6;"></i>
        </button>

        <!-- Search -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search" id="searchInput" oninput="filterTable()" />
        </div>

        <!-- Archive -->
        <button class="btn-archive-outline">
            <i class="bi bi-archive"></i> Archive
        </button>

        <!-- Export -->
        <button class="btn-export">
            <i class="bi bi-upload"></i> Export
        </button>

        <button class="btn-add-user" style="text-decoration:none" id="openCreateModal">
            <i class="bi bi-plus-circle-fill"></i>
            Create Event
        </button>

        <div class="modal fade" id="createModal">
            <div class="modal-dialog">
                <div class="modal-content" id="modalContent">
                </div>
            </div>
        </div>

    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
        <table class="user-table" id="eventTable">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar-event"></i> Title</th>
                    <th><i class="bi bi-text-left"></i> Description</th>
                    <th><i class="bi bi-calendar3"></i> Event Date</th>
                    <th><i class="bi bi-circle-half"></i> Status</th>
                    <th><i class="bi bi-person"></i> Created By</th>
                    <th><i class="bi bi-shield-check"></i> Approved By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="user-name-cell" style="gap:0;">
                                @Html.DisplayFor(modelItem => item.Title)
                            </span>
                        </td>
                        <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.EventDate)</td>
                        <td>
                            @{
                                var status = item.ApprovalStatus?.ToString() ?? "";
                            }
                            @if (status == "Approved")
                            {
                                <span class="badge-active">Approved</span>
                            }
                            else if (status == "Rejected")
                            {
                                <span class="badge-inactive">Rejected</span>
                            }
                            else
                            {
                                <span class="badge-pending">Pending</span>
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.CreatedByUser.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.ApprovedByUser.Email)</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.EventId"
                               class="btn-action btn-edit" style="text-decoration:none;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.EventId"
                               class="btn-action btn-arc ms-1" style="text-decoration:none;">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.EventId"
                               class="btn-action ms-1" style="text-decoration:none; color:#e74c3c; border-color:#f5c0b8; background:#fff5f5; border-radius:7px; padding:5px 12px; font-size:.75rem; font-weight:500; display:inline-flex; align-items:center; gap:4px;">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer / Pagination -->
    <div class="table-footer">
        <div class="rows-info">
            Rows per page
            <select>
                <option>05</option>
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
            &nbsp; 1–5 of @Model.Count() rows
        </div>

        <div class="pagination-btns">
            <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
            <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
            <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
            <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
        </div>
    </div>

</div><!-- /.card-table -->



<script>

    $("#openCreateModal").click(function () {

        $.get("/Events/CreateModal", function (data) {

            $("#modalContent").html(data);

            $("#createModal").modal("show");

        });

    });

</script>

<script>

    $(document).on("submit", "#createEventForm", function (e) {

        e.preventDefault();

        $.post("/Events/Create", $(this).serialize(), function (result) {

            if (result.success) {

                $("#createModal").modal("hide");

                location.reload();

            }

        });

    });

</script>