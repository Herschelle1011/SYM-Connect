@model SYM_CONNECT.ViewModels.EventViewModel
@{
    ViewData["Title"] = "Event Management";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="mb-2">
    <h1 class="page-title">Event Management</h1>
    <p class="page-subtitle">Manage your events and their approval status here.</p>
</div>

<!-- Card / Table -->
@{
    var now = DateTime.Now;
    var monthNames = new[] {
        "January","February","March","April","May","June",
        "July","August","September","October","November","December"
    };
}

<form method="get" asp-action="Index" class="filter-bar" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:1.25rem;">

    <select name="day"
            style="font-size:0.78rem;padding:4px 8px;border-radius:7px;
                       border:1px solid var(--teal-mid);background:#fff;
                       color:var(--teal-dark);min-width:70px;">
        <option value="">-- Day --</option>
        @for (int d = 1; d <= 31; d++)
        {
            <option value="@d">@d</option>
        }
    </select>

    <select name="month"
            style="font-size:0.82rem;padding:5px 10px;border-radius:8px;
               border:1px solid #dee2e6;background:#fff;color:#344;">
        <option value="">-- Month --</option>
        @for (int m = 1; m <= 12; m++)
        {
            if (Model.SelectedMonth == m)
            {
                <option value="@m" selected>@monthNames[m - 1]</option>
            }
            else
            {
                <option value="@m">@monthNames[m - 1]</option>
            }
        }
    </select>

    <select name="year"
            style="font-size:0.82rem;padding:5px 10px;border-radius:8px;
               border:1px solid #dee2e6;background:#fff;color:#344;">
        <option value="">-- Year --</option>
        @for (int y = now.Year; y >= 2000; y--)
        {
            if (Model.SelectedYear == y)
            {
                <option value="@y" selected>@y</option>
            }
            else
            {
                <option value="@y">@y</option>
            }
        }
    </select>

    <button type="submit"
            style="background:#0ab5c4;color:#fff;border:none;
                   border-radius:8px;padding:6px 16px;
                   font-size:0.82rem;font-weight:600;cursor:pointer;">
        <i class="bi bi-funnel-fill"></i> Filter
    </button>

    @if (Model.SelectedMonth.HasValue || Model.SelectedYear.HasValue)
    {
        <a asp-action="Index"
           style="background:transparent;color:#6c757d;
                      border:1px solid #dee2e6;border-radius:8px;
                      padding:5px 14px;font-size:0.82rem;
                      cursor:pointer;text-decoration:none;">
            <i class="bi bi-x-circle"></i> Clear
        </a>
    }
</form>

<div class="card-table">
    <!-- Toolbar -->
    <div class="toolbar">

        <!-- Status Filter Dropdown -->
        <div style="position:relative; display:inline-block;">

            <!-- Trigger Button -->
            <button class="btn-role-filter"
                    id="statusFilterBtn"
                    onclick="toggleStatusDropdown()"
                    type="button">
                <i class="bi bi-funnel-fill"></i>
                <span id="roleFilterLabel">Status</span>
                <i class="bi bi-chevron-down"
                   style="font-size:.65rem;opacity:.6;"></i>
            </button>

            <!-- Dropdown Menu -->
            <div id="statusDropdown"
                 style="display:none;
                position:absolute;
                top:calc(100% + 6px);
                left:0;
                background:#fff;
                border:1px solid #d1f0e8;
                border-radius:10px;
                box-shadow:0 4px 16px rgba(10,181,196,.12);
                min-width:150px;
                z-index:999;
                overflow:hidden;">

                <!-- Each option -->
                <div onclick="applyStatusFilter('All')"
                     class="status-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-people"></i> All
                </div>
                <div onclick="applyStatusFilter('Approved')"
                     class="status-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-shield-check"></i> Approved
                </div>
                <div onclick="applyStatusFilter('Pending')"
                     class="status-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-person-badge"></i> Pending
                </div>
                <div onclick="applyStatusFilter('Rejected')"
                     class="status-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;">
                    <i class="bi bi-person"></i> Rejected
                </div>

            </div>
        </div>


        <!-- Progress Filter Dropdown -->
        <div style="position:relative; display:inline-block;">

            <!-- Trigger Button -->
            <button class="btn-role-filter"
                    id="progressFilterBtn"
                    onclick="toggleProgressDropdown()"
                    type="button">
                <i class="bi bi-funnel-fill"></i>
                <span id="progressFilterLabel">Progress</span>             
                <i class="bi bi-chevron-down"
                   style="font-size:.65rem;opacity:.6;"></i>
            </button>

            <!-- Dropdown Menu -->
            <div id="progressDropdown"
                 style="display:none;
                position:absolute;
                top:calc(100% + 6px);
                left:0;
                background:#fff;
                border:1px solid #d1f0e8;
                border-radius:10px;
                box-shadow:0 4px 16px rgba(10,181,196,.12);
                min-width:150px;
                z-index:999;
                overflow:hidden;">

                <!-- Each option -->
                <div onclick="applyProgressFilter('All')"
                     class="progress-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-people"></i> All
                </div>
                <div onclick="applyProgressFilter('Upcoming')"
                     class="progress-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-shield-check"></i> Upcoming
                </div>
                <div onclick="applyProgressFilter('Ongoing')"
                     class="progress-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;
                    border-bottom:1px solid #f0fbf7;">
                    <i class="bi bi-person-badge"></i> Ongoing
                </div>
                <div onclick="applyProgressFilter('Done')"
                     class="progress-option"
                     style="padding:9px 16px; cursor:pointer;
                    font-size:13px; color:#085041;
                    display:flex; align-items:center; gap:8px;">
                    <i class="bi bi-person"></i> Done
                </div>



            </div>


        </div>






        <!-- Search -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search" id="searchInput" oninput="filterTable()" />
        </div>

        <!-- Archive -->
        <button class="btn-archive-outline"
        data-bs-toggle="modal"
        data-bs-target="#cancelledModal">
            <i class="bi bi-archive"></i> View Cancelled Events
        </button>



        <!-- Export -->
        <a asp-action="ExportPDF"
        asp-controller="Events"
        class="btn-export">
            <i class="bi bi-upload"></i> Export as PDF
        </a>


        <a asp-action="Create"
        class="btn-action btn-edit" style="text-decoration:none;">
            <i class="bi bi-plus-circle-fill"></i>Create
        </a>

        <div class="modal fade" id="createModal">
            <div class="modal-dialog">
                <div class="modal-content" id="modalContent">
                </div>
            </div>
        </div>

    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
        <table class="user-table" id="eventTable">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar-event"></i> Title</th>
                    <th><i class="bi bi-text-left"></i> Description</th>
                    <th><i class="bi bi-calendar3"></i> Event Start</th>
                    <th><i class="bi bi-circle-half"></i> Status</th>
                    <th><i class="bi bi-person"></i> Created By</th>
                    <th><i class="bi bi-shield-check"></i> Approved By</th>
                    <th><i class="bi bi-calendar3"></i> End Date</th>
                    <th><i class="bi bi-stopwatch"></i> Progress</th>


                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var item in Model.Events)
                {
                  
                    <tr>
                        <td>
                            <span class="user-name-cell" style="gap:0;">
                                @Html.DisplayFor(modelItem => item.Title)
                            </span>
                        </td>

                        <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>

                        <td>@Html.DisplayFor(modelItem => item.EventDate)</td>
                        <td>
                            @{
                                var status = item.ApprovalStatus?.ToString() ?? "";
                            }
                            @if (status == "Approved")
                            {
                                <span class="badge-active">Approved</span>
                            }
                            else if (status == "Rejected")
                            {
                                <span class="badge-inactive">Rejected</span>
                            }
                            else
                            {
                                <span class="badge-pending">Pending</span>
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.CreatedByUser.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.ApprovedByUser.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.EndDate)</td>

                        <td>

                            @if (item.ApprovalStatus == "Approved")
                            {
                                @if (item.EventProgress == "Upcoming")
                                {
                                    <span class="badge-pending">Upcoming</span>
                                }
                                else if (item.EventProgress == "Ongoing")
                                {
                                    <span class="badge-active">Ongoing</span>
                                }
                                else
                                {
                                    <span class="badge-done">Done</span>
                                }
                            }
                            else
                            {
                                <span class="badge-inactive">N/A</span>

                            }
                        </td>

                        <td>

                            @if (item.EventProgress == "Done")
                            {                    
                                <a class="btn-action btn-edit"
                                   style="text-decoration:none; pointer-events:none; opacity:0.5; cursor:not-allowed;">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }
                            else
                            {
                                <a asp-action="Edit" asp-route-id="@item.EventId"
                                   class="btn-action btn-edit" style="text-decoration:none;">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }
                            <a asp-action="Details" asp-route-id="@item.EventId"
                               class="btn-action btn-arc ms-1" style="text-decoration:none;">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            @{
                                var hasStarted = Model.Events.Any(e => e.EventId == item.EventId && e.EventDate <= DateTime.Now);
                                if (hasStarted)
                                {
                                    <button class="btn btn-warning btn-sm ms-1"
                                            style="text-decoration:none; cursor: not-allowed; opacity:0.5"
                                            disabled>
                                        Cancel
                                    </button>
                                }
                                else
                                {

                                        <button class="btn btn-warning btn-sm ms-1" style="text-decoration:none"
                                            onclick="openCancelModal(@item.EventId, '@item.Title')">
                                        Cancel
                                    </button>
                                }
                            }
                          

                        </td>
                    </tr>
                    
                }

                <tr id="noSearchResults" style="display:none;">
                    <td colspan="6"
                        style="text-align:center;padding:20px;
                               color:#888;font-size:13px;">
                        <i class="bi bi-search me-1"></i>
                        No events found matching your search.
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

    <!-- Footer / Pagination -->
    <div class="table-footer">
        <div class="rows-info">
            Rows per page
            <select>
                <option>05</option>
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
            &nbsp; 1–5 of @Model.Events.Count() rows
        </div>

        <div class="pagination-btns">
            <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
            <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
            <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
            <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
        </div>
    </div>

</div>


<!-- ── CANCELLED EVENTS MODAL ────────────────────────────── -->
<div class="modal fade" id="cancelledModal" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content"
             style="border-radius:14px;overflow:hidden;
                    border:1px solid var(--teal-light);
                    box-shadow:0 8px 32px rgba(10,181,196,.15);">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
            border-bottom:1px solid var(--teal-mid);
            padding:14px 20px;flex-direction:column;
            align-items:stretch;gap:10px;">

                <!-- Title row -->
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-archive" style="color:var(--teal-dark);font-size:15px;"></i>
                        <h5 class="modal-title mb-0"
                            style="font-size:15px;font-weight:700;color:var(--teal-dark);">
                            Cancelled Events
                        </h5>
                        <span id="cancelledCount"
                              style="background:#e53e3e;color:#fff;font-size:11px;
                         font-weight:700;padding:2px 8px;border-radius:12px;">
                            @(Model.CancelledEvents?.Count() ?? 0)
                        </span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- Day / Month / Year CLIENT-SIDE filter -->
                <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">

                    <select id="cancelDayFilter"
                            onchange="filterCancelledRows()"
                            style="font-size:0.78rem;padding:4px 8px;border-radius:7px;
                       border:1px solid var(--teal-mid);background:#fff;
                       color:var(--teal-dark);min-width:70px;">
                        <option value="">-- Day --</option>
                        @for (int d = 1; d <= 31; d++)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>

                    <select id="cancelMonthFilter"
                            onchange="filterCancelledRows()"
                            style="font-size:0.78rem;padding:4px 8px;border-radius:7px;
                       border:1px solid var(--teal-mid);background:#fff;
                       color:var(--teal-dark);min-width:110px;">
                        <option value="">-- Month --</option>
                        @{
                            var cMonths = new[] { "January","February","March","April","May","June",
                                                                            "July","August","September","October","November","December" };
                        }
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@cMonths[m - 1]</option>
                        }
                    </select>

                    <select id="cancelYearFilter"
                            onchange="filterCancelledRows()"
                            style="font-size:0.78rem;padding:4px 8px;border-radius:7px;
                       border:1px solid var(--teal-mid);background:#fff;
                       color:var(--teal-dark);min-width:80px;">
                        <option value="">-- Year --</option>
                        @for (int y = DateTime.Now.Year; y >= 2000; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>

                    <button type="button"
                            onclick="clearCancelFilter()"
                            style="background:transparent;color:#6c757d;
                       border:1px solid #dee2e6;border-radius:7px;
                       padding:4px 12px;font-size:0.78rem;
                       cursor:pointer;">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                </div>

                <!-- Search bar -->
                <div style="position:relative;">
                    <i class="bi bi-search"
                       style="position:absolute;left:10px;top:50%;
                  transform:translateY(-50%);
                  color:var(--teal-dark);font-size:12px;"></i>
                    <input type="text"
                           id="cancelSearch"
                           placeholder="Search cancelled events..."
                           oninput="filterCancelledRows()"
                           style="width:100%;box-sizing:border-box;
                      padding:7px 12px 7px 30px;
                      border:1px solid var(--teal-mid);
                      border-radius:8px;font-size:13px;
                      background:#f0fbf7;
                      color:var(--teal-dark);outline:none;">
                </div>
            </div>

            <!-- LEGEND -->
            <div style="display:flex;gap:20px;padding:9px 20px;
                        border-bottom:1px solid var(--teal-light);
                        background:#f5fbfd;">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:9px;height:9px;border-radius:50%;
                                background:#22c55e;flex-shrink:0;"></div>
                    <small style="color:var(--text-muted);font-weight:500;">
                        Reactivate — soft delete restore
                    </small>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div style="width:9px;height:9px;border-radius:50%;
                                background:#ef4444;flex-shrink:0;"></div>
                    <small style="color:var(--text-muted);font-weight:500;">
                        Delete — permanent hard delete
                    </small>
                </div>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:12px 16px;">

                @if (Model.CancelledEvents == null || !Model.CancelledEvents.Any())
                {
                    <p class="text-muted text-center py-3">
                        @if (Model.CancelDay.HasValue || Model.CancelMonth.HasValue || Model.CancelYear.HasValue)
                        {
                            <span>No cancelled events found for the selected period.</span>
                        }
                        else
                        {
                            <span>No cancelled events found.</span>
                        }
                    </p>
                }
                else
                {
                    <div class="d-flex flex-column gap-2" id="cancelledEventList">

                        @foreach (var ev in Model.CancelledEvents)
                        {
                            <div class="cancelled-row"
                                 data-title="@ev.Title.ToLower()"
                                 data-cancelled-at="@(ev.CancelledAt.HasValue? ev.CancelledAt.Value.ToString("yyyy-MM-dd") : "")"
                                 style="display:flex;align-items:center;
                                                justify-content:space-between;
                                                padding:11px 14px;
                                                border:1px solid var(--teal-mid);
                                                border-radius:10px;
                                                background:var(--teal-light);
                                                gap:10px;">

                                <!-- Left: info -->
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13.5px;font-weight:700;
                                                        color:var(--teal-dark);white-space:nowrap;
                                                        overflow:hidden;text-overflow:ellipsis;">
                                        @ev.Title
                                    </div>
                                    <div class="d-flex align-items-center gap-1 mt-1">
                                        <i class="bi bi-calendar3" style="font-size:10px;color:var(--teal-dark);"></i>
                                        <span style="font-size:11px;color:var(--teal-dark);font-weight:500;">
                                            Event: @ev.EventDate.ToString("M/d/yyyy h:mm:ss tt")
                                        </span>
                                    </div>
                                    <div class="d-flex align-items-center gap-1 mt-1">
                                        <i class="bi bi-clock-history" style="font-size:10px;color:#e53e3e;"></i>
                                        <span style="font-size:11px;color:#e53e3e;font-weight:500;">
                                            Cancelled: @(ev.CancelledAt.HasValue
                                                                                ? ev.CancelledAt.Value.ToString("MMM dd, yyyy h:mm tt")
                                                                        : "Date not recorded")
                                        </span>
                                    </div>
                                </div>

                                <!-- Right: buttons -->
                                <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                    <form asp-action="Reactivate" asp-route-id="@ev.EventId"
                                          method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" title="Reactivate"
                                                style="width:33px;height:33px;border-radius:8px;
                                                               background:#16a34a;border:none;cursor:pointer;
                                                               display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-arrow-counterclockwise" style="color:#fff;font-size:14px;"></i>
                                        </button>
                                    </form>

                                    <button onclick="openDeleteModal(@ev.EventId, '@Html.Raw(ev.Title.Replace("'", "\\'"))')"
                                            style="display:flex;align-items:center;gap:5px;
                                                           padding:7px 13px;background:#ef4444;color:#fff;
                                                           border:none;border-radius:8px;font-size:12px;
                                                           font-weight:600;cursor:pointer;">
                                        <i class="bi bi-trash" style="font-size:12px;"></i> Delete
                                    </button>
                                </div>
                            </div>
                        }

                        <p id="noCancelResults"
                           style="display:none;text-align:center;font-size:13px;
                                      color:#888;padding:16px 0;margin:0;">
                            No cancelled events match your search.
                        </p>
                    </div>
                }
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        padding:11px 20px;background:#fafeff;">
                <button type="button" data-bs-dismiss="modal"
                        style="background:#5f6b7a;color:#fff;border:none;
                               padding:7px 20px;border-radius:8px;
                               font-size:13px;font-weight:600;cursor:pointer;">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>


<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px; border:2px solid var(--teal-dark);
                    overflow:hidden;">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark); font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Delete
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark); font-size:.9rem;">
                    Are you sure you want to delete
                </p>

                <!-- THIS IS WHERE THE TITLE WILL APPEAR -->
                <p style="color:#e53e3e; font-weight:700;
                           font-size:1rem; margin-top:4px;">
                    "<span id="deleteEventTitle"></span>"?
                </p>

                <p style="color:var(--text-muted); font-size:.8rem;
                           margin-top:8px;">
                    This action cannot be undone.
                </p>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        background:#fafeff;">

                <!-- Go Back button -->
                <button type="button"
                        data-bs-dismiss="modal"
                        style="background:#f1f5f9; color:var(--text-dark);
                               border:1px solid #cdd6df; border-radius:8px;
                               padding:7px 18px; font-size:.83rem;
                               font-weight:600; cursor:pointer;">
                    Go Back
                </button>

                <!-- YES confirm button — this submits the form -->
                <form id="deleteForm" method="post" style="display:inline;" >
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="background:#ef4444; color:#fff;
                                   border:none; border-radius:8px;
                                   padding:7px 18px; font-size:.83rem;
                                   font-weight:600; cursor:pointer;">
                        <i class="bi bi-trash me-1"></i> Yes, Delete It
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>



<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius:14px; border:1px solid var(--teal-light);
                    overflow:hidden;">

            <!-- HEADER -->
            <div class="modal-header"
                 style="background:var(--teal-light);
                        border-bottom:1px solid var(--teal-mid);">
                <h5 class="modal-title"
                    style="color:var(--teal-dark); font-weight:700;">
                    <i class="bi bi-exclamation-triangle-fill
                               text-warning me-2"></i>
                    Confirm Cancel
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body" style="padding:20px 24px;">
                <p style="color:var(--text-dark); font-size:.9rem;">
                    Are you sure you want to cancel
                </p>

                <!-- ✅ UNIQUE id — cancelEventTitle -->
                <p style="color:#e53e3e; font-weight:700;
                           font-size:1rem; margin-top:4px;">
                    "<span id="cancelEventTitle"></span>"?
                </p>

                <p style="color:var(--text-muted); font-size:.8rem;
                           margin-top:8px;">
                    This will mark the event as cancelled.
                </p>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer"
                 style="border-top:1px solid var(--teal-light);
                        background:#fafeff;">

                <!-- Go Back -->
                <button type="button" data-bs-dismiss="modal"
                        style="background:#f1f5f9; color:var(--text-dark);
                               border:1px solid #cdd6df; border-radius:8px;
                               padding:7px 18px; font-size:.83rem;
                               font-weight:600; cursor:pointer;">
                    Go Back
                </button>

                <!-- ✅ form with unique id — cancelForm -->
                <form id="cancelForm" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="background:#f59e0b; color:#fff;
                                   border:none; border-radius:8px;
                                   padding:7px 18px; font-size:.83rem;
                                   font-weight:600; cursor:pointer;">
                        <i class="bi bi-x-circle me-1"></i> Yes, Cancel It
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>