@model SYM_CONNECT.Models.Event
@{
    ViewData["Title"] = "Create Event";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">

    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="page-title">Create Event</h2>
        <p class="page-subtitle">Fill out the form below to create a new event.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background:#ffffff;
         border:1px solid var(--teal-light) !important;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:42px;height:42px;
                             background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-calendar-event-fill text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Event Information</h5>
                    <small class="text-muted">
                        Fields marked with <span class="text-danger">*</span> are required
                    </small>
                </div>
            </div>

            <hr style="border-color:var(--teal-light);" />

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 small mb-3 rounded-3"
                     role="alert">
                </div>

                <div class="row g-3">

                    <!-- Title -->
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label field-label">
                            <i class="bi bi-tag me-1 text-muted"></i>
                            Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control themed-input"
                               placeholder="Enter event title" />
                        <span asp-validation-for="Title"
                              class="text-danger small"></span>
                    </div>

                    <!-- Event Date -->
                    <div class="col-md-3">
                        <label asp-for="EventDate" class="form-label field-label">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>
                            Event Date <span class="text-danger">*</span>
                        </label>
                        <input asp-for="EventDate"
                               type="datetime-local"
                               id="eventDateInput"
                               class="form-control themed-input" />
                        <span asp-validation-for="EventDate"
                              class="text-danger small"></span>
                    </div>

                    <!-- End Date -->
                    <div class="col-md-3">
                        <label asp-for="EndDate" class="form-label field-label">
                            <i class="bi bi-calendar-x me-1 text-muted"></i>
                            End Date
                        </label>
                        <input asp-for="EndDate"
                               type="datetime-local"
                               id="endDateInput"
                               class="form-control themed-input" />
                        <span asp-validation-for="EndDate"
                              class="text-danger small"></span>
                    </div>
                    <!-- Description -->
                    <div class="col-12">
                        <label asp-for="Description" class="form-label field-label">
                            <i class="bi bi-text-left me-1 text-muted"></i>
                            Description
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control themed-input"
                                  rows="3"
                                  placeholder="Enter event description"></textarea>
                        <span asp-validation-for="Description"
                              class="text-danger small"></span>
                    </div>

                    <!-- Created By (readonly) -->
                    <div class="col-md-6">
                        <label asp-for="CreatedBy" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>
                            Created By
                        </label>
                        <input type="text" asp-for="CreatedByUser"
                               class="form-control themed-input"
                               value="@ViewBag.CurrentUser"
                               readonly
                               style="background:#f0f9fa;
                                      color:var(--text-muted);
                                      cursor:not-allowed;" />

                        <input type="hidden"
                               asp-for="CreatedBy"
                               value="@ViewBag.CurrentUserId" />
                    </div>

                    <!-- Event Handler -->
                    <div class="col-md-6">
                        <label asp-for="EventHandlerBy" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>
                            Event Handler (Leaders only)
                        </label>
                        <select asp-for="EventHandlerId"
                                asp-items="@ViewBag.AssignedLeader"
                                class="form-select themed-input">
                            <option value="" disabled selected>-- Select Event Handler --</option>
                        </select>
                        <span asp-validation-for="EventHandlerId" class="text-danger small"></span>
                    </div>

                    <!-- Approval Status -->
                    <div class="col-md-6">
                        <label asp-for="ApprovalStatus" class="form-label field-label">
                            <i class="bi bi-shield-check me-1 text-muted"></i>
                            Approval Status <span class="text-danger">*</span>
                        </label>

                        @{
                                var isAdmin = User.IsInRole("admin"); //show if the role is admin
                            }

                            @if (isAdmin)  //CHECK IF CURRENT ROLE  IS ADMIN
                            {
                            <select asp-for="ApprovalStatus" 
                                    class="form-select themed-input" disabled style=" background:#f0f9fa;
                                    color:var(--text-muted);
                                    cursor:not-allowed;">

                                    <option value="Approved">Approved</option>
                                </select>
                                <span asp-validation-for="ApprovalStatus"
                                class="text-danger small"></span>

                                <input type="hidden" value="Approved" asp-for="ApprovalStatus" />
                            }
                            else //IF NOT DEFAULT TO PENDING
                            {
                                 <select asp-for="ApprovalStatus"
                                    class="form-select themed-input"
                                    disabled
                                    style="background:#f0f9fa;
                                           color:var(--text-muted);
                                           cursor:not-allowed;">
                                         <option value="Pending" selected>Pending</option>
                                </select>

                                <input type="hidden"
                                   asp-for="ApprovalStatus"
                                   value="Pending" />

                            }
                        </div>

                    <!-- Approved By (readonly) -->
                    <div class="col-md-6">
                        <label asp-for="ApprovedBy" class="form-label field-label">
                            <i class="bi bi-person-check me-1 text-muted"></i>
                            Approved By
                        </label>

                        <input type="text" asp-for="ApprovedByUser"
                               class="form-control themed-input"
                               value="@ViewBag.CurrentUser"
                               readonly
                               style="background:#f0f9fa;
                                      color:var(--text-muted);
                                      cursor:not-allowed;" />

                            

                        <input type="hidden"
                               asp-for="ApprovedBy"
                               value="@ViewBag.CurrentUserId" />
                    </div>

                    @* GROUP ASSIGNED SECTION *@
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-person-badge me-1 text-muted"></i>
                            Groups <span class="text-danger">*</span>
                        </label>

                        <select name="AssignedGroupIds"
                                id="groupsSelect"
                                class="form-select themed-input"
                                multiple
                                placeholder="-- Select Groups --">
                            @if (ViewBag.AssignedGroup != null)
                            {
                                @foreach (var group in ViewBag.AssignedGroup as List<SelectListItem>)
                                {
                                    <option value="@group.Value">@group.Text</option>
                                }
                            }
                        </select>
                        <span class="text-danger small">
                        </span>
                    </div>
                </div>

                <hr style="border-color:var(--teal-light);" class="mt-4" />

                <!-- Action Buttons -->
                <div class="d-flex gap-2 pt-2">
                    <button type="submit"
                            class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-calendar-plus"></i> Create Event
                    </button>
                    <a asp-action="Index"
                       class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.default.min.css" />
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

<style>
    .ts-wrapper .ts-control {
        border: 1px solid #ced4da;
        border-radius: 8px;
        padding: 6px 10px;
        min-height: 42px;
    }

    .ts-wrapper.focus .ts-control {
        border-color: #0ab5c4;
        box-shadow: 0 0 0 3px rgba(10, 181, 196, 0.15);
    }

    .ts-dropdown {
        border-radius: 8px;
        border: 1px solid #ced4da;
    }

        .ts-dropdown .option:hover,
        .ts-dropdown .option.active {
            background: #e1f5ee;
            color: #085041;
        }

    .ts-control .item {
        background: #e1f5ee !important;
        color: #085041 !important;
        border-radius: 6px !important;
        font-size: 13px !important;
        border: none !important;
        padding: 3px 10px !important;
    }

        .ts-control .item .remove {
            color: #0F6E56 !important;
            border-left: none !important;
        }
</style>

<script>
    new TomSelect('#groupsSelect', {
        plugins: ['remove_button'],
        placeholder: '-- Select Groups --',
        maxOptions: 50
    });
</script>
