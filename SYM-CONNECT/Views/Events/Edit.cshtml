@model SYM_CONNECT.Models.Event
@{
    ViewData["Title"] = "Edit";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Edit Event</h2>
        <p class="text-muted mb-0">Update the details of this event.</p>
    </div>

    <!-- Card -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- Card Header Row -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-pencil-square text-white fs-5"></i>
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Event Information</h5>
                    <small class="text-muted">Fields marked with <span class="text-danger">*</span> are required</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3 rounded-3" role="alert"></div>
                <input type="hidden" asp-for="EventId" />

                <div class="row g-3">

                    <!-- Title -->
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label field-label">
                            <i class="bi bi-tag me-1 text-muted"></i>Title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control themed-input" placeholder="Enter event title" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Event Date -->
                    <div class="col-md-3">
                        <label asp-for="EventDate" class="form-label field-label">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>
                            Event Date <span class="text-danger">*</span>
                        </label>
                        <input asp-for="EventDate"
                               type="datetime-local"
                               id="eventDateInput"
                               class="form-control themed-input" />
                        <span asp-validation-for="EventDate"
                              class="text-danger small"></span>
                    </div>

                    <!-- End Date -->
                    <div class="col-md-3">
                        <label asp-for="EndDate" class="form-label field-label">
                            <i class="bi bi-calendar-x me-1 text-muted"></i>
                            End Date
                        </label>
                        <input asp-for="EndDate"
                               type="datetime-local"
                               id="endDateInput"
                               class="form-control themed-input" />
                        <span asp-validation-for="EndDate"
                              class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="col-12">
                        <label asp-for="Description" class="form-label field-label">
                            <i class="bi bi-text-left me-1 text-muted"></i>Description
                        </label>
                        <input asp-for="Description" class="form-control themed-input" placeholder="Enter event description" />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>


                    <!-- Created By (readonly) -->
                    <div class="col-md-6">
                        <label asp-for="CreatedBy" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>
                            Created By
                        </label>
                        <input type="text" asp-for="CreatedByUser"
                               class="form-control themed-input"
                               value="@ViewBag.CurrentUser"
                               readonly
                               style="background:#f0f9fa;
                                      color:var(--text-muted);
                                      cursor:not-allowed;" />

                        <input type="hidden"
                               asp-for="CreatedBy"
                               value="@ViewBag.CurrentUserId" />
                    </div>

                    <!-- Approved By -->
                    <div class="col-md-6">
                        <label asp-for="ApprovedBy" class="form-label field-label">
                            <i class="bi bi-person-check me-1 text-muted"></i>Approved By
                        </label>

                              @{
                                var isAdmin = User.IsInRole("admin");
                            }

                            @if (isAdmin)
                            {
                      <input type="text"
                                   class="form-control themed-input"
                                   value="@ViewBag.CurrentUser"
                                   readonly
                                   style="background:#f0f9fa;
                                          color:var(--text-muted);
                                          cursor:not-allowed;" />

                                <input type="hidden"
                                   asp-for="ApprovedBy"
                                   value="@ViewBag.CurrentUserId" />
                            }
                            else
                            {
                                    <input type="text" class="form-control" asp-for="ApprovedByUser"
                                           value="Pending Approval"
                                           readonly />

                                    <input type="hidden"
                                           asp-for="ApprovedBy" />
                            }

                    </div>

                    <!-- Approval Status -->
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-shield-check me-1 text-muted"></i>Approval Status
                        </label>
                        <div class="d-flex gap-3 pt-1">
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="ApprovalStatus" value="Pending" id="statusPending" />
                                <label class="form-check-label" for="statusPending">
                                    <span class="radio-badge badge-pending">Pending</span>
                                </label>
                            </div>
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="ApprovalStatus" value="Approved" id="statusApproved" />
                                <label class="form-check-label" for="statusApproved">
                                    <span class="radio-badge badge-approved">Approved</span>
                                </label>
                            </div>
                            <div class="form-check themed-radio">
                                <input class="form-check-input" type="radio" asp-for="ApprovalStatus" value="Rejected" id="statusRejected" />
                                <label class="form-check-label" for="statusRejected">
                                    <span class="radio-badge badge-rejected">Rejected</span>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="ApprovalStatus" class="text-danger small"></span>
                    </div>

                    @* GROUP ASSIGNED SECTION *@
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-person-badge me-1 text-muted"></i>
                            Groups <span class="text-danger">*</span>
                        </label>

                        @{
                            var selectedIds = Model.AssignedGroups?
                            .Select(g => g.GroupId)
                            .ToList() ?? new List<int>();
                        }

                        <select name="AssignedGroupIds"
                                id="groupsSelect"
                                class="form-select themed-input"
                                multiple
                                placeholder="-- Select Groups --">
                            @if (ViewBag.AssignedGroup != null)
                            {
                                @foreach (var group in ViewBag.AssignedGroup as List<SelectListItem>)
                                {
                                    var isChecked = selectedIds.Contains(int.Parse(group.Value));
                                    <option value="@group.Value"
                                            selected="@(isChecked ? "selected" : null)">
                                        @group.Text
                                    </option>
                                }
                            }
                        </select>
                        <span class="text-danger small">
                       </span>
                    </div>

                </div>

                <hr style="border-color: #e8f7f8;" class="mt-4" />

                <!-- Action Buttons -->
                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-floppy"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }



<style>
    .ts-wrapper .ts-control {
        border: 1px solid #ced4da;
        border-radius: 8px;
        padding: 6px 10px;
        min-height: 42px;
    }

    .ts-wrapper.focus .ts-control {
        border-color: #0ab5c4;
        box-shadow: 0 0 0 3px rgba(10, 181, 196, 0.15);
    }

    .ts-dropdown {
        border-radius: 8px;
        border: 1px solid #ced4da;
    }

        .ts-dropdown .option:hover,
        .ts-dropdown .option.active {
            background: #e1f5ee;
            color: #085041;
        }

    .ts-control .item {
        background: #e1f5ee !important;
        color: #085041 !important;
        border-radius: 6px !important;
        font-size: 13px !important;
        border: none !important;
        padding: 3px 10px !important;
    }

        .ts-control .item .remove {
            color: #0F6E56 !important;
            border-left: none !important;
        }
</style>



    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.default.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>

    <script>
        new TomSelect('#groupsSelect', {
            plugins: ['remove_button'],
            placeholder: '-- Select Groups --',
            maxOptions: 50
        });
    </script>
}