@{
    Layout = "_RegisterLayout";
}

<div class="register-card text-center">

    @* <!-- Logo + System Name -->
    <div class="d-flex justify-content-center align-items-center mb-1 logo-container">

        <img src="/images/Logo.png" class="logo me-2" />

        <h4 class="logo-text m-0">SYM Connect</h4>

    </div> *@

    <h2 class="title mt-3">Sign Up</h2>

    <p class="subtitle e">Enter your details</p>

    <form asp-action="Register" method="post">
        <!-- Username -->
        <div class="mb-3 input-field">
            <i class="bi bi-envelope icon"></i>
            <input class="form-control glass-input" placeholder="Email">
        </div>


        <!-- First Name / Last Name -->
        <div class="fname row mb-3">

            <div class="col">
                <input class="form-control glass-input" placeholder="First Name">
            </div>

            <div class="col">
                <input class="form-control glass-input" placeholder="Last Name">
            </div>

        </div>

        <!-- Role -->
        <div class="mb-3 input-field">
            <i class="bi bi-person-badge icon"></i>
            <select class="form-control glass-input text-dark">
                <option>Select Role</option>
                <option>Admin</option>
                <option>Leader</option>
                <option>Member</option>
            </select>
        </div>

        <!-- Password -->
        <div class="mb-3 input-field">
            <i class="bi bi-lock icon"></i>
            <input type="password" class="form-control glass-input" placeholder="Password">
        </div>


        <!-- Confirm Password -->
        <div class="mb-3 input-field">
            <i class="bi bi-lock-fill icon"></i>
            <input type="password" class="form-control glass-input" placeholder="Confirm Password">
        </div>

        <button type="submit" class="btn register-btn w-100 text-white btn-text">
            Register
        </button>

        <p class="mt-3 register-link">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">
                Click here
            </a>
        </p>
    </form>
</div>