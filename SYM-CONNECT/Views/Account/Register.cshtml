@{
    Layout = "_RegisterLayout"; //REGISTER PAGE LAYOUT
}

<!-- MAIN WRAPPER -->
<div class="login-container">

    <!-- REGISTER CARD -->
    <div class="login-form">

        <!-- TITLE -->
        <h2 class="login-title">Register</h2>

        <!-- FORM → AccountController.Register -->
        <form asp-action="Register" method="post">

            <!-- FIRST + LAST NAME -->
            <div class="name-row">

                <div class="form-group">
                    <label>First name</label>
                    <input class="form-input" placeholder="Enter first name"> <!--NOT BOUND YET-->
                </div>

                <div class="form-group">
                    <label>Last name</label>
                    <input class="form-input" placeholder="Enter last name"> <!--NOT BOUND YET-->
                </div>

            </div>


            <!-- EMAIL -->
            <div class="form-group">
                <label>Email</label>

                <div class="input-wrapper">
                    <input type="email"
                           class="form-input"
                           placeholder="Enter your email"> <!--EMAIL INPUT-->

                    <i class="bi bi-envelope"></i> <!--ICON-->
                </div>
            </div>


            <!-- ROLE -->
            <div class="form-group">
                <label>Role</label>

                <div class="input-wrapper">
                    <select class="form-input">
                        <!--DROPDOWN-->
                        <option>Select Role</option>
                        <option>Admin</option>
                        <option>Leader</option>
                        <option>Member</option>
                    </select>

                    <i class="bi bi-chevron-down"></i>
                </div>
            </div>

            <!-- PASSWORD -->
            <div class="form-group">
                <label>Password</label>
                <div class="input-wrapper">
                    <input type="password"
                           class="form-input"
                           placeholder="Enter password">
                    <i class="bi bi-eye-slash"></i> <!--TOGGLE ICON-->
                </div>
            </div>


            <!-- CONFIRM PASSWORD -->
            <div class="form-group">
                <label>Confirm Password</label>

                <div class="input-wrapper">
                    <input type="password"
                           class="form-input"
                           placeholder="Confirm password">

                    <i class="bi bi-eye-slash"></i>
                </div>
            </div>


            <!-- TERMS -->
            <div class="terms">

                <input type="checkbox"> <!--NOT VALIDATED YET-->

                <label>
                    I agree to the
                    <a href="#">Terms & Conditions</a>
                </label>

            </div>


            <!-- SUBMIT -->
            <button type="submit" class="login-btn">
                Sign In <!--SUBMIT FORM-->
            </button>


            <!-- LOGIN LINK -->
            <p class="signup-text">

                Already have an account?

                <a asp-controller="Account" asp-action="Login">
                    Sign In.
                </a> <!--GO TO LOGIN PAGE-->

            </p>

        </form>

    </div>

</div>