@model SYM_CONNECT.ViewModel.LoginViewModel
@{
    Layout = "_LoginLayout";
}

<div class="login-card text-center">

    <!-- Logo + System Name -->
    <div class="d-flex justify-content-center align-items-center mb-1 logo-container">

        <img src="/images/Logo.png" class="logo me-2" />

        <h4 class="logo-text m-0">SYM Connect</h4>

    </div>

    <h2 class="title mt-2 m-3">Sign In</h2>

    <p class="subtitle text-white">Welcome back! Enter your existing account.</p>

    <form asp-action="Login" method="post" asp-controller="Account">

        @Html.AntiForgeryToken()
        <div class="mb-3 input-field">
            <i class="bi bi-envelope icon"></i>
            <input type="email" class="form-control custom-input" placeholder="Enter email" asp-for="Email"/>
                <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3 input-field">
            <i class="bi bi-lock icon"></i>
            <input type="password" class="form-control custom-input" placeholder="Enter password" asp-for="Password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>


        <div class="d-flex justify-content-between mb-3">

            <div class="remember-text">
                <input type="checkbox" />
                <label>Remember me</label>
            </div>

            <a href="#" class="forgot-link">Forgot Password?</a>

        </div>

        <button type="submit" class="btn login-btn w-100 text-white btn-text">
            Login
        </button>

        <p class="mt-3 register-link">
            New member of SYM?
            <a asp-controller="Account" asp-action="Register">
                Click here to enroll
            </a>
        </p>
    </form>
</div>