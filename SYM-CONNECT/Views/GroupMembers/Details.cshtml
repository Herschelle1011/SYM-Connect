@model SYM_CONNECT.Models.GroupMember
@{
    ViewData["Title"] = "Member Details";
    Layout = "_Layout";

    var user = Model.User;
    var group = Model.Group;
    var initial = user?.FullName?.Length > 0 ? user.FullName[0].ToString().ToUpper() : "?";
    var statusColor = user?.Status == "Active" ? "#16a34a" : "#e53e3e";
    var statusBg = user?.Status == "Active" ? "#e1f5ee" : "#fde8e8";
}

<style>
    .member-profile-card {
        background: #fff;
        border: 1px solid #b2e9ef;
        border-radius: 16px;
        padding: 28px;
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
        box-shadow: 0 2px 12px rgba(10,181,196,.08);
        margin-bottom: 1.5rem;
    }

    .member-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0ab5c4, #07869b);
        color: #fff;
        font-size: 2rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(10,181,196,.3);
    }

    .member-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 1.5rem;
    }

    .info-card {
        background: #fff;
        border: 1px solid #b2e9ef;
        border-radius: 12px;
        padding: 16px 20px;
        box-shadow: 0 2px 8px rgba(10,181,196,.06);
    }

    .info-card-label {
        font-size: 0.72rem;
        color: #9ca3af;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .info-card-value {
        font-size: 0.92rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .points-highlight {
        background: linear-gradient(135deg, #0ab5c4, #07869b);
        border-radius: 12px;
        padding: 20px 24px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 16px rgba(10,181,196,.25);
    }

    .attendance-table th {
        font-size: 0.75rem;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 10px 14px;
        background: #f0f9fa;
        border-bottom: 1px solid #b2e9ef;
    }

    .attendance-table td {
        font-size: 0.83rem;
        color: #374151;
        padding: 11px 14px;
        border-bottom: 1px solid #e8fafb;
        vertical-align: middle;
    }

    .attendance-table tr:last-child td {
        border-bottom: none;
    }

    .attendance-table tr:hover td {
        background: #f0f9fa;
    }

    .section-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #07869b;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 7px;
    }
</style>

<!-- Page Header -->
<div class="mb-3">
    <h1 class="page-title">
        <i class="bi bi-person-badge-fill me-2" style="color:#0ab5c4;"></i>
        Member Profile
    </h1>
    <p class="page-subtitle">Full details and attendance history for this group member.</p>
</div>

<!-- PROFILE CARD -->
<div class="member-profile-card">

    <!-- AVATAR -->
    <div class="member-avatar">@initial</div>

    <!-- NAME + EMAIL + STATUS -->
    <div style="flex:1;min-width:180px;">
        <div style="font-size:1.3rem;font-weight:800;color:#1a1a2e;line-height:1.2;">
            @(user?.FullName ?? "—")
        </div>
        <div style="font-size:0.83rem;color:#6b7280;margin-top:3px;">
            <i class="bi bi-envelope me-1"></i>@(user?.Email ?? "—")
        </div>
        <div style="margin-top:8px;">
            <span style="background:@statusBg;color:@statusColor;
                         border-radius:20px;padding:3px 12px;
                         font-size:0.72rem;font-weight:700;">
                <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>
                @(user?.Status ?? "—")
            </span>
        </div>
    </div>

    <!-- ROLE BADGE -->
    <div style="text-align:right;">
        <div style="background:#e8fafb;border:1px solid #b2e9ef;
                    border-radius:10px;padding:8px 16px;
                    font-size:0.78rem;font-weight:700;color:#07869b;">
            <i class="bi bi-person-fill me-1"></i>
            @(user?.Role ?? "Member")
        </div>
        <div style="font-size:0.7rem;color:#9ca3af;margin-top:6px;">
            Member ID #@Model.GroupMemberId
        </div>
    </div>

</div>

<!-- POINTS HIGHLIGHT -->
<div class="points-highlight">
    <div>
        <div style="font-size:0.78rem;opacity:.8;font-weight:600;letter-spacing:.05em;text-transform:uppercase;">
            <i class="bi bi-star-fill me-1"></i> Total Earned Points
        </div>
        <div style="font-size:2.2rem;font-weight:900;line-height:1.1;margin-top:4px;">
            @Model.TotalEarnedPoints
            <span style="font-size:0.9rem;font-weight:500;opacity:.8;">pts</span>
        </div>
    </div>
    <i class="bi bi-trophy-fill" style="font-size:3rem;opacity:.25;"></i>
</div>

<!-- INFO GRID -->
<div class="member-info-grid">

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-diagram-3-fill" style="color:#0ab5c4;"></i> Group
        </div>
        <div class="info-card-value">@(group?.Name ?? "—")</div>
    </div>

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-geo-alt-fill" style="color:#0ab5c4;"></i> Region
        </div>
        <div class="info-card-value">@(group?.Region ?? "—")</div>
    </div>

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-geo-fill" style="color:#0ab5c4;"></i> Sub Region
        </div>
        <div class="info-card-value">@(group?.SubRegion ?? "—")</div>
    </div>

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-person-fill" style="color:#0ab5c4;"></i> Group Leader
        </div>
        <div class="info-card-value">@(group?.Leader?.FullName ?? "—")</div>
    </div>

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-calendar-plus-fill" style="color:#0ab5c4;"></i> Joined At
        </div>
        <div class="info-card-value">
            @(user?.CreatedAt.ToString("MMM d, yyyy") ?? "—")
        </div>
    </div>

    <div class="info-card">
        <div class="info-card-label">
            <i class="bi bi-shield-fill" style="color:#0ab5c4;"></i> Group Status
        </div>
        <div class="info-card-value">
            @if (group?.Status == "Active")
            {
                <span style="color:#16a34a;">Active</span>
            }
            else
            {
                <span style="color:#e53e3e;">@(group?.Status ?? "—")</span>
            }
        </div>
    </div>

</div>

<!-- ATTENDANCE HISTORY -->
<div class="card-table" style="margin-bottom:1.5rem;">
    <div style="padding:16px 20px;border-bottom:1px solid #e8fafb;">
        <div class="section-title">
            <i class="bi bi-calendar-check-fill"></i>
            Attendance History
            @if (Model.User?.Attendances != null)
            {
                <span style="background:#e8fafb;color:#07869b;border:1px solid #b2e9ef;
                                 border-radius:20px;padding:1px 10px;
                                 font-size:0.7rem;font-weight:700;">
                    @Model.User.Attendances.Count() records
                </span>
            }
        </div>
    </div>

    <div style="overflow-x:auto;">
        <table class="user-table attendance-table" style="margin:0;">
            <thead>
                <tr>
                    <th><i class="bi bi-hash"></i> #</th>
                    <th><i class="bi bi-calendar-event"></i> Event</th>
                    <th><i class="bi bi-calendar3"></i> Date</th>
                    <th><i class="bi bi-star-fill"></i> Points</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.User?.Attendances == null || !Model.User.Attendances.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align:center;padding:28px;color:#9ca3af;font-size:13px;">
                            <i class="bi bi-calendar-x me-2"></i>
                            No attendance records found for this member.
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    @foreach (var att in Model.User.Attendances.OrderByDescending(a => a.AttendanceDate))
                    {
                        <tr>
                            <td style="color:#9ca3af;font-size:0.75rem;">@i</td>
                            <td style="font-weight:600;color:#1a1a2e;">
                                @(att.Event?.Title ?? "—")
                            </td>
                            <td>@att.AttendanceDate.ToString("MMM d, yyyy h:mm tt")</td>
                            <td>
                                <span style="background:#fef9e7;color:#b7800a;
                                                     border:1px solid #fde68a;border-radius:20px;
                                                     padding:2px 10px;font-size:0.72rem;font-weight:700;">
                                    <i class="bi bi-star-fill me-1"></i>@att.PointsEarned pts
                                </span>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ACTION BUTTONS -->
<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.GroupMemberId"
       class="btn btn-save d-flex align-items-center gap-1"
       style="text-decoration:none;">
        <i class="bi bi-pencil"></i> Edit Member
    </a>
    <a asp-action="Index"
       class="btn btn-back d-flex align-items-center gap-1"
       style="text-decoration:none;">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>
