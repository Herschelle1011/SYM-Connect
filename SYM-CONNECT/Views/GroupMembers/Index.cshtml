@model IEnumerable<SYM_CONNECT.Models.GroupMember>
@{
    ViewData["Title"] = "Group Members";
    Layout = "_Layout";
}

<div class="container-fluid px-4 py-4">

    <!-- Page Header -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Group Members</h2>
        <p class="text-muted mb-0">Manage and view all group member assignments.</p>
    </div>

    <!-- Table Card -->
    <div class="card-table">
        <div class="toolbar">
            <h6 class="fw-bold mb-0" style="color:#2d3a3f;">
                All Members
                <span style="color:#90adb8; font-weight:400; font-size:.85rem;">
                    @Model.Count() total
                </span>
            </h6>

            <!-- Add Member Button -->
            <a asp-action="Create"
               class="btn d-inline-flex align-items-center gap-1"
               style="background:#0ab5c4; color:#fff; border-radius:8px; font-size:.85rem; padding:6px 16px;">
                <i class="bi bi-person-plus-fill"></i> Add Member
            </a>

            <!-- Search -->
            <div class="search-wrap ms-auto">
                <i class="bi bi-search"></i>
                <input type="text" placeholder="Search members..."
                       id="searchInput" oninput="filterTable()" />
            </div>
        </div>

        <div style="overflow-x:auto;">
            <table class="user-table" id="userTable">
                <thead>
                    <tr>
                        <th><i class="bi bi-people"></i> Group</th>
                        <th><i class="bi bi-person"></i> Member</th>
                        <th><i class="bi bi-envelope"></i> Email</th>
                        <th><i class="bi bi-gear"></i> Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold" style="color:#2d3a3f;">
                                    @item.Group?.Name
                                </span>
                            </td>
                            <td>
                                <span class="user-name-cell">
                                    <img src="https://i.pravatar.cc/40?u=@item.UserId"
                                         class="user-avatar" alt="" />
                                    @item.User?.FullName
                                </span>
                            </td>
                            <td style="color:#555; font-size:.9rem;">
                                @item.User?.Email
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.GroupMemberId"
                                       class="btn btn-sm d-inline-flex align-items-center gap-1"
                                       style="background:#e8f7f8; color:#0ab5c4; border-radius:6px; font-size:.8rem; padding:4px 10px;">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.GroupMemberId"
                                       class="btn btn-sm d-inline-flex align-items-center gap-1"
                                       style="background:#f0f4f5; color:#2d3a3f; border-radius:6px; font-size:.8rem; padding:4px 10px;">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                   
                                </div>
                            </td>
                        </tr>
                    }

                    <tr id="noSearchResults" style="display:none;">
                        <td colspan="6"
                            style="text-align:center;padding:20px;
                        color:#888;font-size:13px;">
                            <i class="bi bi-search me-1"></i>
                            No users found matching your search.
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>
    </div>
</div>
