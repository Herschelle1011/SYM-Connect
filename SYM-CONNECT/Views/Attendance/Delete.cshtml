@model SYM_CONNECT.Models.Attendance

@{
    ViewData["Title"] = "Delete"; //PAGE TITLE
}

<h1>Delete</h1>

<!-- CONFIRMATION MESSAGE -->
<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Attendance</h4>
    <hr />

    <!-- DISPLAY DETAILS (READ-ONLY DATA BEFORE DELETE) -->
    <dl class="row">

        <!-- ATTENDANCE DATE -->
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AttendanceDate) <!--LABEL-->
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AttendanceDate) <!--VALUE-->
        </dd>

        <!-- POINTS -->
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.PointsEarned)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.PointsEarned)
        </dd>

        <!-- USER -->
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.User)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.User.Email) <!--SHOW USER EMAIL-->
        </dd>

        <!-- EVENT -->
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Event)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Event.Description) <!--SHOW EVENT DESCRIPTION-->
        </dd>

    </dl>

    <!-- DELETE FORM -->
    <!-- SUBMITS TO AttendanceController.Delete (POST) -->
    <form asp-action="Delete">

        <!-- HIDDEN ID (REQUIRED TO DELETE CORRECT RECORD) -->
        <input type="hidden" asp-for="AttendanceId" />

        <!-- DELETE BUTTON -->
        <input type="submit" value="Delete" class="btn btn-danger" /> |

        <!-- BACK BUTTON -->
        <a asp-action="Index">Back to List</a>

    </form>
</div>