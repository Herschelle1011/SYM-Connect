@model SYM_CONNECT.Models.Attendance
@{
    ViewData["Title"] = "Create"; //PAGE TITLE
    Layout = "_Layout"; //MAIN LAYOUT
}

<div class="container-fluid px-4 py-4">
    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold" style="color: #0ab5c4;">Create Attendance</h2>
        <p class="text-muted mb-0">Fill out the form below to log a new attendance record.</p>
    </div>

    <!-- CARD WRAPPER -->
    <div class="card border-0 rounded-4 shadow-sm" style="background: #ffffff;">
        <div class="card-body p-4">

            <!-- CARD HEADER -->
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="rounded-3 d-flex align-items-center justify-content-center"
                      style="width:40px;height:40px;background:linear-gradient(135deg,#0ab5c4,#07869b);">
                    <i class="bi bi-person-check-fill text-white fs-5"></i> <!--ICON-->
                </span>
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Attendance Information</h5>
                    <small class="text-muted">Fields marked with <span class="text-danger">*</span> are required</small>
                </div>
            </div>

            <hr style="border-color: #e8f7f8;" />

            <!-- FORM AttendanceController.Create -->
            <form asp-action="Create">

                <!-- VALIDATION SUMMARY -->
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2 small mb-3 rounded-3" role="alert"></div>

                <div class="row g-3">

                    <!-- USER SELECT -->
                    <div class="col-md-6">
                        <label asp-for="UserId" class="form-label field-label">
                            <i class="bi bi-person me-1 text-muted"></i>Username <span class="text-danger">*</span>
                        </label>

                        <!-- DROPDOWN FROM ViewBag.MemberId -->
                        <select id="UserId" class="form-select themed-input" name="UserId" asp-for="UserId" asp-items="@(ViewData["MemberId"] as SelectList)">
                            <option value="">-- Select Member --</option>
                        </select>

                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>

                    <!-- EVENT SELECT -->
                    <div class="col-md-6">
                        <label asp-for="EventId" class="form-label field-label">
                            <i class="bi bi-calendar-event me-1 text-muted"></i>Event Name <span class="text-danger">*</span>
                        </label>

                        <!-- DROPDOWN FROM ViewBag.EventList -->
                        <select id="EventId" asp-for="EventId" name="EventId" class="form-select themed-input" asp-items="@(ViewData["EventList"] as SelectList)"
                                onchange="loadMembers(this.value)">
                            <option value="">-- Select Event --</option>
                        </select>


                        <span asp-validation-for="EventId" class="text-danger small"></span>
                    </div>

                    <!-- DISPLAY CURRENT TIME ONLY -->
                    <div class="col-md-6">
                        <label class="form-label field-label">
                            <i class="bi bi-calendar3 me-1 text-muted"></i>
                            Current Time
                        </label>

                        <!-- READONLY DISPLAY (NOT SUBMITTED) -->
                        <input type="text"
                               id="currentTimeDisplay"
                               class="form-control themed-input"
                               readonly
                               style="background:#f0f9fa;
                                      color:var(--text-muted);
                                      cursor:not-allowed;" />

                        <span asp-validation-for="AttendanceDate" class="text-danger small"></span>
                    </div>

                    <!-- HIDDEN FIELD  THIS IS WHAT ACTUALLY GETS SENT for DATABASE PURPOSES -->
                    <input type="hidden" asp-for="AttendanceDate" id="attendanceDateHidden" />

                    <!-- POINTS -->
                    <div class="col-md-6">
                        <label asp-for="PointsEarned" class="form-label field-label">
                            <i class="bi bi-star me-1 text-muted"></i>Points Earned <span class="text-danger">*</span>
                        </label>

                        <input asp-for="PointsEarned"
                               class="form-control themed-input"
                               placeholder="Enter points earned" />

                        <span asp-validation-for="PointsEarned" class="text-danger small"></span>
                    </div>

                </div>

                <hr style="border-color: #e8f7f8;" class="mt-4" />

                <!-- ACTION BUTTONS -->
                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-save d-flex align-items-center gap-1">
                        <i class="bi bi-plus-circle"></i> Create Attendance <!--SUBMIT-->
                    </button>

                    <a asp-action="Index" class="btn btn-back d-flex align-items-center gap-1">
                        <i class="bi bi-arrow-left"></i> Back to List <!--NAV BACK-->
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial"); //LOAD VALIDATION SCRIPTS
    }

    <script>
        function updateClock() {
            const now = new Date(); //GET CURRENT TIME

            //FORMAT DATE
            const date = now.toLocaleDateString('en-US', {
                month: '2-digit',
                day:   '2-digit',
                year:  'numeric'
            });

            //FORMAT TIME
            const time = now.toLocaleTimeString('en-US', {
                hour:   '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: true
            });

            const ms = String(now.getMilliseconds()).padStart(3, '0'); //MILLISECONDS

            //DISPLAY FORMAT
            const [timePart, period] = time.split(' ');

            document.getElementById('currentTimeDisplay').value =
                `${date} ${timePart} ${period}`;
        }

        //RUN IMMEDIATELY + LOOP
        updateClock();
        setInterval(updateClock, 1); //REALTIME UPDATE


        function loadMembers(eventId) {
    if (!eventId) {
        // CLEAR DROPDOWN IF NO EVENT SELECTED
        const select = document.getElementById('UserId');
        select.innerHTML = '<option value="">-- Select Member --</option>';
        return;
    }

    fetch(`/Attendance/GetMembersByEvent?eventId=${eventId}`)
        .then(res => res.json())
        .then(members => {
            const select = document.getElementById('UserId');
            select.innerHTML = '<option value="">-- Select Member --</option>';

            if (members.length === 0) {
                select.innerHTML += '<option disabled>No members found for this event</option>';
                return;
            }

            members.forEach(m => {
                select.innerHTML += `<option value="${m.id}">${m.display}</option>`;
            });
        })
        .catch(() => {
            console.error('Failed to load members');
        });
}

// ON PAGE LOAD — if event is already selected (e.g. after validation fail), reload members
document.addEventListener('DOMContentLoaded', () => {
    const eventId = document.getElementById('EventId').value;
    if (eventId) loadMembers(eventId);
});
    </script>
}