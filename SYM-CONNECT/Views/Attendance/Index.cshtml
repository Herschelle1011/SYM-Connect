@model IEnumerable<SYM_CONNECT.Models.Attendance>

@{
    ViewData["Title"] = "Attendance Management"; //PAGE TITLE
    Layout = "_Layout"; //MAIN LAYOUT
}

<!-- HEADER -->
<div class="mb-2">
    <h1 class="page-title">Attendance Management</h1>
    <p class="page-subtitle">Track and manage member attendance and points earned here.</p>
</div>

<!-- CARD / TABLE WRAPPER -->
<div class="card-table">

    <!-- TOOLBAR -->
    <div class="toolbar">

        <!-- SEARCH INPUT -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text"
                   placeholder="Search"
                   id="searchInput"
                   oninput="filterTable()" /> <!--CALL JS FILTER-->
        </div>

        <!-- EXPORT PDF -->
        <a asp-action="ExportPDF"
           asp-controller="Attendance"
           class="btn-export">
            <i class="bi bi-upload"></i> Export as PDF
        </a>

        <!-- ADD NEW -->
        <a asp-action="Create"
           class="btn-add-user"
           style="text-decoration:none;">
            <i class="bi bi-plus-circle-fill"></i> Add Attendance
        </a>

    </div>

    <!-- TABLE WRAPPER -->
    <div style="overflow-x:auto;">
        <table class="user-table" id="attendanceTable">

            <!-- TABLE HEADER -->
            <thead>
                <tr>
                    <th><i class="bi bi-calendar3"></i> Attendance Date</th>
                    <th><i class="bi bi-star"></i> Points Earned</th>
                    <th><i class="bi bi-person"></i> User</th>
                    <th><i class="bi bi-calendar-event"></i> Event</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <!-- TABLE BODY -->
            <tbody id="tableBody">

                @foreach (var item in Model)
                {
                    <tr>

                        <!-- DATE -->
                        <td>@Html.DisplayFor(modelItem => item.AttendanceDate)</td>

                        <!-- POINTS -->
                        <td>
                            <span style="
                                    background:#e8f4ff;
                                    color:#3a7bd5;
                                    border:1px solid #b8d4f8;
                                    border-radius:20px;
                                    padding:4px 14px;
                                    font-size:.74rem;
                                    font-weight:600;">
                                <i class="bi bi-star-fill" style="font-size:.65rem;"></i>
                                @Html.DisplayFor(modelItem => item.PointsEarned)
                            </span>
                        </td>

                        <!-- USER -->
                        <td>
                            <span class="user-name-cell" style="gap:8px;">
                                <img src="https://i.pravatar.cc/40"
                                     alt=""
                                     class="user-avatar" /> <!--STATIC AVATAR-->
                                @Html.DisplayFor(modelItem => item.User.Email)
                            </span>
                        </td>

                        <!-- EVENT -->
                        <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @Html.DisplayFor(modelItem => item.Event.Title)
                        </td>

                        <!-- ACTIONS -->
                        <td>

                            <!-- EDIT -->
                            <a asp-action="Edit"
                               asp-route-id="@item.AttendanceId"
                               asp-controller="Attendance"
                               class="btn-action btn-edit"
                               style="text-decoration:none;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>

                            <!-- DETAILS -->
                            <a asp-action="Details"
                               asp-route-id="@item.AttendanceId"
                               class="btn-action btn-arc ms-1"
                               style="text-decoration:none;">
                                <i class="bi bi-eye"></i> Details
                            </a>

                            <!-- DELETE BUTTON (OPENS MODAL) -->
                            <button type="button"
                                    onclick="openDeleteArchiveModal(@item.AttendanceId, '@item.User?.FullName', '@item.Event?.Title', @item.PointsEarned)"
                                    class="btn-action ms-1"
                                    style="text-decoration:none;color:#e74c3c;border-color:#f5c0b8;
                                               background:#fff5f5;border-radius:7px;padding:5px 12px;
                                               font-size:.75rem;font-weight:500;display:inline-flex;
                                               align-items:center;gap:4px;border:1px solid #f5c0b8;cursor:pointer;">
                                <i class="bi bi-archive"></i> Delete
                            </button>

                        </td>
                    </tr>
                }

                <!-- NO RESULTS ROW -->
                <tr id="noSearchResults" style="display:none;">
                    <td colspan="6"
                        style="text-align:center;padding:20px;
                               color:#888;font-size:13px;">
                        <i class="bi bi-search me-1"></i>
                        No users found matching your search.
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

    <!-- FOOTER / PAGINATION -->
    <div class="table-footer">

        <!-- ROW COUNT -->
        <div class="rows-info">
            Rows per page
            <select>
                <option>05</option>
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
            &nbsp; 1–5 of @Model.Count() rows
        </div>

        <!-- PAGINATION BUTTONS (UI ONLY) -->
        <div class="pagination-btns">
            <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
            <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
            <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
            <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
        </div>
    </div>

    <!-- DELETE MODAL -->
    <div class="modal fade" id="archiveDeleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">

                <!-- MODAL HEADER -->
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-archive me-2"></i>Delete Attendance Record
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <!-- MODAL BODY -->
                <div class="modal-body">

                    <!-- USER -->
                    <p class="mb-1">You are about to delete the attendance of:</p>
                    <h6 class="fw-bold" id="modalUserName">—</h6>

                    <!-- EVENT -->
                    <p class="mb-1 mt-2">Event:</p>
                    <h6 class="fw-bold" id="modalEventTitle">—</h6>

                    <!-- POINT WARNING -->
                    <div class="alert alert-warning mt-3 mb-0 d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>
                            <strong id="modalPoints">0</strong> points will be deducted.
                        </span>
                    </div>
                </div>

                <!-- MODAL FOOTER -->
                <div class="modal-footer">

                    <!-- CANCEL -->
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <!-- DELETE FORM -->
                    <form id="archiveDeleteForm" method="post">
                        @Html.AntiForgeryToken() <!--SECURITY-->
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Confirm Delete
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
