@model IEnumerable<SYM_CONNECT.Models.Attendance>

@{
    ViewData["Title"] = "Attendance Management";
    Layout = "_Layout";
}

<!-- Page Header -->
<div class="mb-2">
    <h1 class="page-title">Attendance Management</h1>
    <p class="page-subtitle">Track and manage member attendance and points earned here.</p>
</div>

<!-- Card / Table -->
<div class="card-table">

    <!-- Toolbar -->
    <div class="toolbar">

        <!-- Filter -->
        <button class="btn-role-filter">
            <i class="bi bi-funnel-fill"></i> Filter
            <i class="bi bi-chevron-down" style="font-size:.65rem;opacity:.6;"></i>
        </button>

        <!-- Search -->
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" placeholder="Search" id="searchInput" oninput="filterTable()" />
        </div>

        <!-- Archive -->
        <button class="btn-archive-outline">
            <i class="bi bi-archive"></i> Archive
        </button>

        <!-- Export -->
        <button class="btn-export">
            <i class="bi bi-upload"></i> Export
        </button>

        <!-- Add Attendance -->
        <a asp-action="Create" class="btn-add-user" style="text-decoration:none;">
            <i class="bi bi-plus-circle-fill"></i> Add Attendance
        </a>

    </div>

    <!-- Table -->
    <div style="overflow-x:auto;">
        <table class="user-table" id="attendanceTable">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar3"></i> Attendance Date</th>
                    <th><i class="bi bi-star"></i> Points Earned</th>
                    <th><i class="bi bi-person"></i> User</th>
                    <th><i class="bi bi-calendar-event"></i> Event</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.AttendanceDate)</td>
                        <td>
                            <span style="
                                    background:#e8f4ff;
                                    color:#3a7bd5;
                                    border:1px solid #b8d4f8;
                                    border-radius:20px;
                                    padding:4px 14px;
                                    font-size:.74rem;
                                    font-weight:600;">
                                <i class="bi bi-star-fill" style="font-size:.65rem;"></i>
                                @Html.DisplayFor(modelItem => item.PointsEarned)
                            </span>
                        </td>
                        <td>
                            <span class="user-name-cell" style="gap:8px;">
                                <img src="https://i.pravatar.cc/40" alt="" class="user-avatar" />
                                @Html.DisplayFor(modelItem => item.User.Email)
                            </span>
                        </td>
                        <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @Html.DisplayFor(modelItem => item.Event.Description)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.AttendanceId" asp-controller="Attendance"
                               class="btn-action btn-edit" style="text-decoration:none;">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.AttendanceId"
                               class="btn-action btn-arc ms-1" style="text-decoration:none;">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.AttendanceId"
                               class="btn-action ms-1"
                               style="text-decoration:none;color:#e74c3c;border-color:#f5c0b8;background:#fff5f5;border-radius:7px;padding:5px 12px;font-size:.75rem;font-weight:500;display:inline-flex;align-items:center;gap:4px;">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer / Pagination -->
    <div class="table-footer">
        <div class="rows-info">
            Rows per page
            <select>
                <option>05</option>
                <option>10</option>
                <option>25</option>
                <option>50</option>
            </select>
            &nbsp; 1–5 of @Model.Count() rows
        </div>

        <div class="pagination-btns">
            <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
            <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
            <button class="pg-btn active">1</button>
            <button class="pg-btn">2</button>
            <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
            <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
            <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
        </div>
    </div>


