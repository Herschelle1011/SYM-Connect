<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SYM Connect</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @* TOAST NOTIFICATION CSS *@
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/Dashboard.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
</head>

<body>

    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="sidebar-brand">
                <img src="~/images/logo.png" alt="SYM Logo"
                     onerror="this.style.background='#00bcd4';this.removeAttribute('src');this.textContent='S';" />
                <span class="brand-name">SYM Connect</span>
            </div>

            <p class="nav-label">MENU</p>

            <nav class="sidebar-nav">

                @* //DASHBOARD BUTTON *@
                <a asp-controller="Home" asp-action="Dashboard"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" &&
                                                   ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard"
                                                   ? "active" : "")">
                    <i class="bi bi-grid-fill"></i> Dashboard
                </a>

                @* //USERS MANAGEMENT BUTTON *@
                <a asp-controller="Users" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users"
                                                   ? "active" : "")">
                    <i class="bi bi-person-fill"></i> User
                </a>

                @* //EVENTS MANAGEMENT BUTTON *@
                <a asp-controller="Events" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events"
                                                   ? "active" : "")">
                    <i class="bi bi-calendar-event-fill"></i> Events
                </a>

                @* //ATTENDANCE MANAGEMENT BUTTON *@
                <a asp-controller="Attendance" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Attendance"
                                                   ? "active" : "")">
                    <i class="bi bi-check-circle-fill"></i> Attendance
                </a>

                @* //SYM GROUP MANAGEMENT BUTTON *@
                   <a asp-controller="SYMGroups" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SYMGroups"
                                                   ? "active" : "")">
                    <i class="bi bi-people-fill"></i> Groups
                </a>

                @* //GROUP MEMBERS MANAGEMENT BUTTON *@
                <a asp-controller="GroupMembers" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "GroupMembers"
                                                                     ? "active" : "")">
                    <i class="bi bi-heart-pulse-fill"></i> Members
                </a>

                @* //REPORT MANAGEMENT BUTTON *@
                <a asp-controller="Reports" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports")">
                    <i class="bi bi-bar-chart-fill"></i> Reports
                </a>


                @* LOGOUT SECTION *@
                <form asp-controller="Home" asp-action="Logout" method="post" style="margin-top: auto;">
                    @Html.AntiForgeryToken()
                    <button type="button"
                            class="nav-link"
                            style="width:100%; background:none; border:none; text-align:left; cursor:pointer;"
                            data-bs-toggle="modal"
                            data-bs-target="#logoutModal">
                        <i class="bi bi-box-arrow-left"></i> Logout
                    </button>
                </form>

            </nav>

        </aside>

        <!-- Add this anywhere before </body> -->
        <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-body text-center py-4">
                        <div class="logout-icon-wrap mb-3">
                            <i class="bi bi-box-arrow-left"></i>
                        </div>
                        <h5 class="modal-title fw-semibold mb-1" id="logoutModalLabel">Logging out?</h5>
                        <p class="text-muted small mb-4">You'll need to sign in again to access your account.</p>

                        <div class="d-flex justify-content-center gap-2">
                            <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <form asp-controller="Home" asp-action="Logout" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger px-4">
                                    Yes, logout
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <main class="main-content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>

    </div>


    <!-- Scripts -->
    @section Scripts {
        @* <script>
            function filterTable() {
                const input = document.getElementById('searchInput').value.toLowerCase();
                const rows = document.querySelectorAll('#tableBody tr');
                rows.forEach(row => {
                    row.style.display = row.innerText.toLowerCase().includes(input) ? '' : 'none';
                }); 
            }


        </script> *@
    }


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/site-modals.js"></script>


    <script>
        toastr.options = {
            positionClass: "toast-top-right",
            timeOut: 3000,          // disappears after 3 seconds
            closeButton: true,
            progressBar: true,      // shows a timer bar
        };

        // check if controller have a message
        @if (TempData["Success"] != null)
        {
                <text>toastr.success("@TempData["Success"]");</text>
        }
        @if (TempData["Error"] != null)
        {
                <text>toastr.error("@TempData["Error"]");</text>
        }
        @if (TempData["Warning"] != null)
        {
                <text>toastr.warning("@TempData["Warning"]");</text>
        }
        @if (TempData["Info"] != null)
        {
                <text>toastr.info("@TempData["Info"]");</text>
        }
    </script>


    @await RenderSectionAsync("Scripts", required: false)

</body>














</html>