@model SYM_CONNECT.ViewModel.ReportViewModel
@using SYM_CONNECT.Models
@{
    ViewData["Title"] = "Events Report";
    Layout = "_Layout";

    int filterYear = Model.SelectedYear ?? DateTime.Now.Year;
    int filterMonth = Model.SelectedMonth ?? 0;

    var monthLabels = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    var eventsPerMonthData = string.Join(",", Model.EventsPerMonth);

    // Derive upcoming vs done from RecentEvents for the mini-feed
    var upcomingEvents = Model.RecentEvents.Where(e => e.EventDate > DateTime.Now).ToList();
    var doneEvents = Model.RecentEvents.Where(e => e.EventDate <= DateTime.Now).ToList();

    int upcomingCount = Model.RecentEvents.Count(e => e.EventProgress == "Upcoming");
    int ongoingCount = Model.RecentEvents.Count(e => e.EventProgress == "Ongoing");
    int doneCount = Model.RecentEvents.Count(e => e.EventProgress == "Done");
}

<style>
    /* ── Shared base (mirrors GroupReport theme) ───────────────── */
    .er-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .er-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
    }

        .er-title span {
            color: #0ab5c4;
        }

    .er-meta {
        font-size: 0.78rem;
        color: #6c757d;
        margin-top: 3px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .er-meta b {
            color: #374151;
        }

    /* Filter bar */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

        .filter-bar select,
        .filter-bar input[type=number] {
            font-size: 0.82rem;
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            background: #fff;
            color: #374151;
        }

    .btn-go {
        background: #0ab5c4;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-go:hover {
            background: #07869b;
        }

    .btn-export {
        background: #fff;
        color: #0ab5c4;
        border: 1.5px solid #0ab5c4;
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-export:hover {
            background: #e8fafb;
            color: #07869b;
        }

    /* Section label */
    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #6c757d;
        margin: 1.4rem 0 .7rem;
        padding-left: 2px;
    }

    /* Stat cards */
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 18px 16px;
        box-shadow: 0 2px 8px rgba(10,181,196,.07);
        border: 1px solid #e8fafb;
        position: relative;
        overflow: hidden;
        transition: transform .18s, box-shadow .18s;
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(10,181,196,.13);
        }

    .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        margin-bottom: 10px;
    }

    .stat-label {
        font-size: 0.7rem;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 2px;
    }

    .stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1;
        margin-bottom: 5px;
    }

    .stat-delta {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
    }

    .delta-up {
        background: #e1f5ee;
        color: #0f6e56;
    }

    .delta-down {
        background: #fde8e8;
        color: #b91c1c;
    }

    .delta-neu {
        background: #f1f5f9;
        color: #64748b;
    }

    .stat-accent {
        position: absolute;
        bottom: -10px;
        right: -10px;
        width: 55px;
        height: 55px;
        border-radius: 50%;
        opacity: .07;
    }

    /* Icon color helpers */
    .ic-teal {
        background: #e8fafb;
        color: #0ab5c4;
    }

    .ic-green {
        background: #e1f5ee;
        color: #0f6e56;
    }

    .ic-yellow {
        background: #fef9e7;
        color: #b7800a;
    }

    .ic-blue {
        background: #e6f0fd;
        color: #185fa5;
    }

    .ic-purple {
        background: #f0eeff;
        color: #534ab7;
    }

    .ic-red {
        background: #fde8e8;
        color: #b91c1c;
    }

    /* Card table */
    .card-table {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8fafb;
        box-shadow: 0 2px 8px rgba(10,181,196,.05);
        overflow: hidden;
    }

    .ct-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 16px;
        border-bottom: 1px solid #f0f9fa;
    }

        .ct-header h6 {
            margin: 0;
            font-size: 0.85rem;
            font-weight: 600;
            color: #1a1a2e;
        }

        .ct-header small {
            font-size: 0.72rem;
            color: #6c757d;
        }

    .icon-sm {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #e8fafb;
        color: #0ab5c4;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.82rem;
        flex-shrink: 0;
    }

    .chart-body {
        padding: 14px 16px;
    }

    .chart-wrap {
        position: relative;
        width: 100%;
        height: 220px;
    }

    /* Table */
    .ev-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.79rem;
    }

        .ev-table th {
            padding: 7px 12px;
            font-size: 0.68rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: .04em;
            background: #f8fbfc;
            border-bottom: 1px solid #e8fafb;
        }

        .ev-table td {
            padding: 9px 12px;
            border-bottom: 1px solid #f0f9fa;
            color: #374151;
            vertical-align: middle;
        }

        .ev-table tr:last-child td {
            border-bottom: none;
        }

        .ev-table tr:hover td {
            background: #f8fbfc;
        }

    .table-footer {
        padding: 7px 14px;
        font-size: 0.71rem;
        color: #6c757d;
        border-top: 1px solid #f0f9fa;
        background: #f8fbfc;
    }

    /* Badges */
    .badge-done {
        background: #e8fafb;
        color: #07869b;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-upcoming {
        background: #fef9e7;
        color: #b7800a;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-ongoing {
        background: #e1f5ee;
        color: #0f6e56;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-pending {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-approved {
        background: #e1f5ee;
        color: #0f6e56;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-rejected {
        background: #fde8e8;
        color: #b91c1c;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-cancelled {
        background: #f0f0f0;
        color: #6c757d;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Progress bar */
    .progress-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .progress-track {
        flex: 1;
        background: #e8fafb;
        border-radius: 4px;
        height: 6px;
        min-width: 60px;
    }

    .progress-fill {
        background: #0ab5c4;
        border-radius: 4px;
        height: 6px;
    }

    .pf-green {
        background: #1D9E75;
    }

    .pf-yellow {
        background: #b7800a;
    }

    .pf-red {
        background: #e24b4a;
    }

    /* Group pills in event row */
    .group-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .group-pill {
        background: #e8fafb;
        color: #07869b;
        border: 1px solid #b2e9ef;
        border-radius: 20px;
        padding: 1px 9px;
        font-size: 0.68rem;
        font-weight: 600;
    }

    /* Timeline / activity feed */
    .feed-list {
        padding: 12px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .feed-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .feed-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-top: 4px;
        flex-shrink: 0;
    }

    .fd-teal {
        background: #0ab5c4;
    }

    .fd-yellow {
        background: #b7800a;
    }

    .fd-green {
        background: #1D9E75;
    }

    .fd-red {
        background: #e24b4a;
    }

    .feed-content .fc-title {
        font-size: 0.8rem;
        font-weight: 600;
        color: #1a1a2e;
    }

    .feed-content .fc-meta {
        font-size: 0.7rem;
        color: #9ca3af;
        margin-top: 1px;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 28px 16px;
        color: #9ca3af;
        font-size: 0.8rem;
        font-style: italic;
    }

    /* Donut summary strip */
    .donut-strip {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        padding: 14px 16px;
        border-top: 1px solid #f0f9fa;
    }

    .donut-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.75rem;
        color: #374151;
    }

    .donut-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
</style>

<div class="container-fluid px-4 py-4">

    <!-- ── Page Header ─────────────────────────────────────────── -->
    <div class="er-header">
        <div>
            <div class="er-title">
                <i class="bi bi-calendar-event-fill me-2" style="color:#0ab5c4;"></i>
                Events Report — <span>Overview</span>
            </div>
            <div class="er-meta">
                <span><i class="bi bi-calendar3"></i> Year: <b>@filterYear</b></span>
                @if (filterMonth > 0)
                {
                    <span><i class="bi bi-calendar-month"></i> Month: <b>@(new System.Globalization.CultureInfo("en-US").DateTimeFormat.GetMonthName(filterMonth))</b></span>
                }
                <span><i class="bi bi-lightning-charge-fill" style="color:#0ab5c4;"></i> Total Events: <b>@Model.TotalEvents</b></span>
            </div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="ExportPDF" asp-controller="Reports" class="btn-export">
                <i class="bi bi-file-earmark-pdf-fill"></i> Export PDF
            </a>
            <a asp-action="Index" asp-controller="Reports" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Reports
            </a>
        </div>
    </div>

    <!-- ── Filter Bar ──────────────────────────────────────────── -->
    <form method="get" asp-action="EventsReport" class="filter-bar">
        <select name="month">
            <option value="">All Months</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(filterMonth == m)">
                    @(new System.Globalization.CultureInfo("en-US").DateTimeFormat.GetMonthName(m))
                </option>
            }
        </select>
        <input type="number" name="year" value="@filterYear" min="2000" max="@DateTime.Now.Year" style="width:90px;" />
        <button type="submit" class="btn-go"><i class="bi bi-funnel-fill"></i> Filter</button>
    </form>

    <!-- ── Overview Stats ──────────────────────────────────────── -->
    <div class="section-label">Overview — @filterYear</div>
    <div class="row g-3 mb-3">

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-teal"><i class="bi bi-calendar-event-fill"></i></div>
                <div class="stat-label">Total Events</div>
                <div class="stat-value">@Model.TotalEvents</div>
                <span class="stat-delta delta-neu">All time</span>
                <div class="stat-accent" style="background:#0ab5c4;"></div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-green"><i class="bi bi-check-circle-fill"></i></div>
                <div class="stat-label">Completed</div>
                <div class="stat-value">@Model.DoneEvents</div>
                <span class="stat-delta delta-up">Done</span>
                <div class="stat-accent" style="background:#1D9E75;"></div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-yellow"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-label">Upcoming</div>
                <div class="stat-value">@(Model.TotalEvents - Model.DoneEvents)</div>
                <span class="stat-delta delta-neu">Scheduled</span>
                <div class="stat-accent" style="background:#b7800a;"></div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-blue"><i class="bi bi-people-fill"></i></div>
                <div class="stat-label">Total Members</div>
                <div class="stat-value">@Model.TotalMembers</div>
                <span class="stat-delta delta-neu">In system</span>
                <div class="stat-accent" style="background:#378add;"></div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-teal"><i class="bi bi-diagram-3-fill"></i></div>
                <div class="stat-label">Total Groups</div>
                <div class="stat-value">@Model.TotalGroups</div>
                <span class="stat-delta delta-neu">Active groups</span>
                <div class="stat-accent" style="background:#0ab5c4;"></div>
            </div>
        </div>

        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                @{
                    double completionRate = Model.TotalEvents > 0
                    ? Math.Round((double)Model.DoneEvents / Model.TotalEvents * 100, 1) : 0;
                    string rateClass = completionRate >= 80 ? "ic-green" : completionRate >= 50 ? "ic-yellow" : "ic-red";
                    string rateDelta = completionRate >= 80 ? "delta-up" : completionRate >= 50 ? "delta-neu" : "delta-down";
                }
                <div class="stat-icon @rateClass"><i class="bi bi-bar-chart-fill"></i></div>
                <div class="stat-label">Completion Rate</div>
                <div class="stat-value">@completionRate<small style="font-size:1rem;">%</small></div>
                <span class="stat-delta @rateDelta">
                    @(completionRate >= 80 ? "Excellent" : completionRate >= 50 ? "Average" : "Low")
                </span>
                <div class="stat-accent" style="background:#0ab5c4;"></div>
            </div>
        </div>

    </div>

    <!-- ── Monthly Chart + Activity Feed ───────────────────────── -->
    <div class="section-label">Activity Timeline</div>
    <div class="row g-3 mb-3">

        <!-- Bar Chart -->
        <div class="col-12 col-lg-8">
            <div class="card-table">
                <div class="ct-header">
                    <div class="icon-sm"><i class="bi bi-graph-up"></i></div>
                    <div>
                        <h6>Events Per Month — @filterYear</h6>
                        <small>Monthly distribution of events held</small>
                    </div>
                </div>
                <div class="chart-body">
                    <div class="chart-wrap">
                        <canvas id="eventsMonthChart" role="img" aria-label="Bar chart of events per month">Monthly events data.</canvas>
                    </div>
                </div>
                <div class="donut-strip">
                    <span class="donut-label"><span class="donut-dot" style="background:#0ab5c4;"></span> Events in @filterYear</span>
                </div>
            </div>
        </div>

        <!-- Status donut -->
        <div class="col-12 col-lg-4">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm"><i class="bi bi-pie-chart-fill"></i></div>
                    <div>
                        <h6>Event Status Split</h6>
                        <small>Distribution of event statuses</small>
                    </div>
                </div>
                <div class="chart-body d-flex align-items-center justify-content-center" style="min-height:180px;">
                    <div class="chart-wrap" style="height:180px; max-width:200px;">
                        <canvas id="statusDonut" role="img" aria-label="Donut chart of event statuses">Status distribution.</canvas>
                    </div>
                </div>
                <div class="donut-strip" style="justify-content:center; gap:16px;">
                    <span class="donut-label"><span class="donut-dot" style="background:#1D9E75;"></span> Done (@Model.DoneEvents)</span>
                    <span class="donut-label"><span class="donut-dot" style="background:#b7800a;"></span> Upcoming (@(Model.TotalEvents - Model.DoneEvents))</span>
                </div>
            </div>
        </div>

    </div>
  

    <!-- ── Recent Events Breakdown ─────────────────────────────── -->
    <div class="section-label">Recent Events</div>
    <div class="row g-3 mb-4">

        <!-- Event Table -->
        <div class="col-12 col-lg-8">
            <div class="card-table">
                <div class="ct-header">
                    <div class="icon-sm"><i class="bi bi-calendar-event-fill"></i></div>
                    <div>
                        <h6>Event List</h6>
                        <small>All Events — @filterYear</small>
                    </div>
                </div>
                <div style="overflow-x:auto;">
                    <table class="ev-table">
                        <thead>
                            <tr>
                                <th><i class="bi bi-calendar-event"></i> Event</th>
                                <th><i class="bi bi-calendar3"></i> Date</th>
                                <th><i class="bi bi-calendar-x"></i> End Date</th>
                                <th><i class="bi bi-diagram-3"></i> Groups</th>
                                <th><i class="bi bi-people-fill"></i>Attendees</th>
                                <th><i class="bi bi-circle-half"></i> Progress</th>
                                <th><i class="bi bi-patch-check"></i> Approval</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.RecentEvents.Any())
                            {
                                <tr><td colspan="6" class="empty-state">No events found for selected period.</td></tr>
                            }
                            @foreach (var ev in Model.RecentEvents)
                            {
                                
                                bool cancelled = ev.IsActuallyCancelled;
                                if(!cancelled){
                                <tr>
                                    <td>
                                        <div style="font-weight:600;color:#1a1a2e;">
                                            @if (cancelled)
                                            {
                                                <span style="text-decoration:line-through;color:#9ca3af;">@ev.Title</span>
                                            }
                                            else
                                            {
                                                @ev.Title
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(ev.Description))
                                        {
                                            <div style="font-size:0.7rem;color:#9ca3af;margin-top:1px;">
                                                @(ev.Description.Length > 50 ? ev.Description.Substring(0, 50) + "…" : ev.Description)
                                            </div>
                                        }
                                    </td>
                                    <td style="white-space:nowrap;">@ev.EventDate.ToString("MMM d, yyyy")<br /><span style="font-size:0.68rem;color:#9ca3af;">@ev.EventDate.ToString("h:mm tt")</span></td>
                                    <td style="white-space:nowrap;color:#6c757d;font-size:0.75rem;">
                                        @(ev.EndDate.HasValue? ev.EndDate.Value.ToString("MMM d, yyyy") : "—")
                                    </td>
                                    <td>
                                        @if (ev.AssignedGroups.Any())
                                        {
                                            <div class="group-pills">
                                                @foreach (var g in ev.AssignedGroups.Take(3))
                                                {
                                                    <span class="group-pill">@g.Name</span>
                                                }
                                                @if (ev.AssignedGroups.Count > 3)
                                                {
                                                    <span class="group-pill">+@(ev.AssignedGroups.Count - 3)</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af;font-size:0.75rem;">No groups</span>
                                        }
                                    </td>

                                    <td>
                                                   <a asp-action="Attendees" 
                               asp-controller="Reports" 
                               asp-route-eventId="@ev.EventId"   
                               class="btn-add-user" 
                               style="text-decoration:none;">
                                View All
                            </a>
                                        
                                                        </td>

                                    <td>
                                     
                                            @switch (ev.EventProgress)
                                            {
                                                case "Done":
                                                    <span class="badge-done">Done</span>
                                                    break;
                                                case "Ongoing":
                                                    <span class="badge-active">OnGoing</span>
                                                    break;                       
                                            }
                                        
                                    </td>
                                    <td>
                                        @switch (ev.ApprovalStatus)
                                        {
                                            case EventStatus.Approved:
                                                <span class="badge-approved">Approved</span>
                                                break;
                                            case EventStatus.Rejected:
                                                <span class="badge-rejected">Rejected</span>
                                                break;
                                            default:
                                                <span class="badge-pending">Pending</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <span>Showing latest @Model.RecentEvents.Count event(s)</span>
                </div>
            </div>
        </div>

        <!-- Activity Feed -->
        <div class="col-12 col-lg-4">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fef9e7;color:#b7800a;"><i class="bi bi-activity"></i></div>
                    <div>
                        <h6>Activity Feed</h6>
                        <small>Recent event activity</small>
                    </div>
                </div>
                <div class="feed-list">
                    @if (!Model.RecentEvents.Any())
                    {
                        <div class="empty-state">No recent activity.</div>
                    }
                    @foreach (var ev in Model.RecentEvents.Take(8))
                    {
                        bool isCancelled = ev.IsActuallyCancelled;
                        string dotClass = isCancelled ? "fd-red"
                        : ev.EventProgress == "Done" ? "fd-green"
                        : ev.EventProgress == "Ongoing" ? "fd-teal"
                        : "fd-yellow";
                        <div class="feed-item">
                            <div class="feed-dot @dotClass"></div>
                            <div class="feed-content">
                                <div class="fc-title">@ev.Title</div>
                                <div class="fc-meta">
                                    <i class="bi bi-calendar3"></i> @ev.EventDate.ToString("MMM d, yyyy")
                                    &nbsp;·&nbsp;
                                    @if (isCancelled)
                                    {
                                        <span style="color:#b91c1c;">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span>@ev.EventProgress</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const teal   = '#0ab5c4';
        const green  = '#1D9E75';
        const yellow = '#b7800a';

        // ── Monthly events bar chart ──
        new Chart(document.getElementById('eventsMonthChart'), {
            type: 'bar',
            data: {
                labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                datasets: [{
                    label: 'Events',
                    data: [@Html.Raw(eventsPerMonthData)],
                    backgroundColor: teal,
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f0f9fa' },
                        ticks: { color: '#6c757d', font: { size: 11 }, stepSize: 1 }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#6c757d', font: { size: 11 }, autoSkip: false }
                    }
                }
            }
        });

        // ── Status donut chart ──
        new Chart(document.getElementById('statusDonut'), {
            type: 'doughnut',
            data: {
                labels: ['Completed', 'Upcoming'],
                datasets: [{
                    data: [@Model.DoneEvents, @(Model.TotalEvents - Model.DoneEvents)],
                    backgroundColor: [green, yellow],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ` ${ctx.label}: ${ctx.raw} events`
                        }
                    }
                }
            }
        });
    </script>
}
