@model SYM_CONNECT.ViewModel.ReportViewModel
@{
    ViewData["Title"] = "Reports";
    Layout = "_Layout";

    var groupLabels = string.Join(",", Model.Groups.Select(g => $"'{g.Name}'"));
    var groupCounts = string.Join(",", Model.Groups.Select(g => g.GroupMembers.Count));
    var monthlyData = string.Join(",", Model.EventsPerMonth);
}

<div class="container-fluid px-4 py-4">

    <!-- Page Header -->
    <div class="mb-3 d-flex align-items-start justify-content-between flex-wrap gap-2">
        <div>
            <h1 class="page-title">
                <i class="bi bi-bar-chart-line-fill me-2"></i>Reports
            </h1>
            <p class="page-subtitle">Overview of members, leaders, groups, and events.</p>
        </div>


        <!-- Export -->
        <a asp-action="ExportPDF"
           asp-controller="Reports"
           class="btn-export">
            <i class="bi bi-upload"></i> Export as PDF
        </a>



        <!-- Month + Year Filter -->
<form method="get" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">
    <select name="month" class="form-select form-select-sm" style="width:auto;">
        <option value="">-- Month --</option>
        @{
            var months = new[] { "January","February","March","April","May","June",
                                 "July","August","September","October","November","December" };
            for (int m = 1; m <= 12; m++)
            {
                        <option value="@m" selected="@(Model.SelectedMonth == m)">@months[m - 1]</option>
            }
        }
    </select>

    <select name="year" class="form-select form-select-sm" style="width:auto;">
        <option value="">-- Year --</option>
        @for (int y = DateTime.Now.Year; y >= 2000; y--)
        {
                    <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
                }
    </select>

    <button type="submit" class="btn btn-sm btn-primary">
        <i class="bi bi-funnel-fill"></i> Filter
    </button>

    @if (Model.SelectedMonth.HasValue || Model.SelectedYear.HasValue)
    {
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-x-circle"></i> Clear
        </a>
    }
</form>
    </div>


</div>

<!-- SUMMARY CARDS -->
<div class="section-label">Summary Overview</div>
<div class="row g-3 mb-1">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-people-fill"></i></div>
            <div class="stat-label">Total Members</div>
            <div class="stat-value">@Model.TotalMembers</div>
            <span class="stat-sub sub-teal">All roles</span>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-person-check-fill"></i></div>
            <div class="stat-label">Active Members</div>
            <div class="stat-value">@Model.ActiveMembers</div>
            <span class="stat-sub sub-green">Active</span>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-shield-fill-check"></i></div>
            <div class="stat-label">Leaders</div>
            <div class="stat-value">@Model.TotalLeaders</div>
            <span class="stat-sub sub-teal">Assigned</span>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-diagram-3-fill"></i></div>
            <div class="stat-label">Groups</div>
            <div class="stat-value">@Model.TotalGroups</div>
            <span class="stat-sub sub-teal">Total</span>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-calendar-event-fill"></i></div>
            <div class="stat-label">Total Events</div>
            <div class="stat-value">@Model.TotalEvents</div>
            <span class="stat-sub sub-teal">All time</span>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="stat-card">
            <div class="icon-wrap"><i class="bi bi-calendar-plus-fill"></i></div>
            <div class="stat-label">Done</div>
            <div class="stat-value">@Model.DoneEvents</div>
            <span class="stat-sub sub-yellow">Events</span>
        </div>
    </div>
</div>

<!-- MEMBERS REPORT -->
<div class="section-label">Members Report</div>
<div class="row g-3 mb-1">

    <!-- Donut Chart -->
    <div class="col-md-4">
        <div class="card-table h-100">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-pie-chart-fill"></i></div>
                <div>
                    <h6>Member Status</h6>
                    <small>Active vs Inactive breakdown</small>
                </div>
            </div>
            <div class="chart-body">
                <div class="donut-row">
                    <canvas id="memberDonut"
                            style="max-width:150px;max-height:150px;"></canvas>
                    <ul class="legend-list">
                        <li>
                            <span class="legend-dot" style="background:#0ab5c4;"></span>
                            Active &mdash; <strong>@Model.ActiveMembers</strong>
                        </li>
                        <li>
                            <span class="legend-dot" style="background:#ef4444;"></span>
                            Inactive &mdash; <strong>@Model.InactiveMembers</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Members per Group Table -->
    <div class="col-md-8">
        <div class="card-table">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-table"></i></div>
                <div>
                    <h6>Members per Group</h6>
                    <small>Distribution across all groups</small>
                </div>
            </div>
            <div style="overflow-x:auto;">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th><i class="bi bi-diagram-3"></i> Group</th>
                            <th><i class="bi bi-shield-check"></i> Leader</th>
                            <th><i class="bi bi-people"></i> Members</th>
                            <th><i class="bi bi-bar-chart"></i> Fill Rate</th>
                            <th><i class="bi bi-circle-half"></i> Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in Model.Groups)
                        {
                            var initials = string.Concat(g.Name.Split(' ')
                            .Where(w => !string.IsNullOrEmpty(w))

                            .Take(2).Select(w => w[0]));
                            var count = g.GroupMembers.Count;
                            var fillPct = Model.MaxMembers > 0
                            ? (int)((count / (double)Model.MaxMembers) * 100) : 0;
                            <tr>
                                <td>
                                    <span class="user-name-cell">
                                        <div class="avatar-initials">@initials</div>
                                        @g.Name
                                    </span>
                                </td>
                                <td>@(g.Leader?.FullName ?? "—")</td>
                                <td><strong>@count</strong></td>
                                <td>
                                    <div class="progress-wrap">
                                        <small class="text-muted">@fillPct%</small>
                                        <div class="progress-track">
                                            <div class="progress-fill"
                                                 style="width:@fillPct%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (g.Status == "Active")
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <span>@Model.Groups.Count groups total</span>
            </div>
        </div>
    </div>
</div>

<!-- LEADERS & GROUPS -->
<div class="section-label">Leaders &amp; Groups Report</div>
<div class="row g-3 mb-1">

    <!-- Leaders Table -->
    <div class="col-md-6">
        <div class="card-table">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-shield-fill-check"></i></div>
                <div>
                    <h6>Leaders Overview</h6>
                    <small>Leaders and their assigned groups</small>
                </div>
            </div>
            <div style="overflow-x:auto;">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th><i class="bi bi-person"></i> Leader</th>
                            <th><i class="bi bi-diagram-3"></i> Group</th>
                            <th><i class="bi bi-people"></i> Members</th>
                            <th><i class="bi bi-circle-half"></i> Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ld in Model.LeaderData)
                        {
                            <tr>
                                <td>
                                    <span class="user-name-cell">
                                        <img src="https://i.pravatar.cc/40?u=@ld.Leader.Id"
                                             class="user-avatar" />
                                        @ld.Leader.FullName
                                    </span>
                                </td>
                                <td>
                                    @if (ld.Group != null)
                                    {
                                        @ld.Group.Name
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Unassigned</span>
                                    }
                                </td>
                                <td>@(ld.Members?.ToString() ?? "—")</td>
                                <td>
                                    @if (ld.Group == null)
                                    {
                                        <span class="badge-inactive">No Group</span>
                                    }
                                    else if (ld.Group.Status == "Active")
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <span>@Model.TotalLeaders leaders total</span>
            </div>
        </div>
    </div>

    <!-- Bar Chart -->
    <div class="col-md-6">
        <div class="card-table h-100">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-bar-chart-fill"></i></div>
                <div>
                    <h6>Members per Group</h6>
                    <small>Bar chart comparison</small>
                </div>
            </div>
            <div class="chart-body">
                <div class="chart-wrap">
                    <canvas id="groupBar"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- EVENTS REPORT -->
<div class="section-label">Events Report</div>
<div class="row g-3 mb-4">

    <div class="col-md-7">
        <div class="card-table h-100">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-calendar3"></i></div>
                <div>
                    <h6>Events per Month</h6>
                    <small>Monthly event activity (@(Model.SelectedYear ?? DateTime.Now.Year))</small>
                </div>
            </div>
            <div class="chart-body">
                <div class="chart-wrap">
                    <canvas id="eventsBar"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card-table">
            <div class="ct-header">
                <div class="icon-sm"><i class="bi bi-list-check"></i></div>
                <div>
                    <h6>Recent Events</h6>
                    <small>Latest event records</small>     
                    <input type="date"
                           id="doneDateFilter"
                           class="form-control"
                           onchange="filterDoneByDate()"
                           style="max-width:200px;">
                </div>
            </div>
            <div style="overflow-x:auto;">

               

                <table class="user-table">
                    <thead>
                        <tr>
                            <th><i class="bi bi-calendar-event"></i> Event</th>
                            <th><i class="bi bi-diagram-3"></i> Group</th>
                            <th><i class="bi bi-calendar3"></i> Date</th>
                            <th><i class="bi bi-circle-half"></i> Status</th>
                        </tr>
                    </thead>
                    <tbody id="doneTableBody">
                        @foreach (var ev in Model.RecentEvents)
                        {
                            {
                            var groupName = ev.AssignedGroups.Any()
                            ? string.Join(", ", ev.AssignedGroups.Select(g => g.Name))
                            : "All Groups";
                                var isDone = ev.EventDate < DateTime.Now;

                            <tr>
                                <td>@ev.Title</td>
                                <td>@groupName</td>
                                    <td data-date="@ev.EventDate.ToString("yyyy-MM-dd")">
                                        @ev.EventDate.ToString("MMM d")
                                    </td>
                                    <td>
                                    @if (isDone)
                                    {
                                        <span class="badge-done">Done</span>
                                    }
                                    else
                                    {
                                        <span class="badge-upcoming">Upcoming</span>
                                    }
                                </td>
                            </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="table-footer">
                <span>@Model.RecentEvents.Count events shown</span>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>


                function filterDoneByDate() {

            var selectedDate = document.getElementById('doneDateFilter').value;

            var rows = document.querySelectorAll('#doneTableBody tr');

            rows.forEach(function (row) {

        var dateText = row.cells[2]?.dataset.date;
        var rowDate = new Date(dateText);

                // Convert table date to Date object
                var rowDate = new Date(dateText);
                var selected = selectedDate ? new Date(selectedDate) : null;

                // Check if DONE (past event)
                var isDone = rowDate < new Date();

                if (!selectedDate) {
                    // If no date selected → show all DONE events
                    row.style.display = isDone ? '' : 'none';
                } else {
                    // Match selected date + DONE only
                    var sameDate =
                        rowDate.toDateString() === selected.toDateString();

                    row.style.display =
                        (sameDate && isDone) ? '' : 'none';
                }
            });
        }



        const teal = '#0ab5c4', tealDark = '#07869b',
              tealMid = '#55d0db', tealPale = '#c2edf1', red = '#ef4444';

        new Chart(document.getElementById('memberDonut'), {
            type: 'doughnut',
            data: {
                labels: ['Active', 'Inactive'],
                datasets: [{
                    data: [@Model.ActiveMembers, @Model.InactiveMembers],
                    backgroundColor: [teal, red],
                    borderWidth: 0, hoverOffset: 6
                }]
            },
            options: {
                cutout: '72%',
                plugins: { legend: { display: false } },
                responsive: true, maintainAspectRatio: true
            }
        });

        new Chart(document.getElementById('groupBar'), {
            type: 'bar',
            data: {
                labels: [@Html.Raw(groupLabels)],
                datasets: [{
                    label: 'Members',
                    data: [@Html.Raw(groupCounts)],
                    backgroundColor: [teal, tealDark, tealMid, tealPale],
                    borderRadius: 8, borderSkipped: false
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f0f9fa' },
                         ticks: { color: '#6c757d', font: { size: 11 } } },
                    x: { grid: { display: false },
                         ticks: { color: '#6c757d', font: { size: 11 } } }
                }
            }
        });

        new Chart(document.getElementById('eventsBar'), {
            type: 'bar',
            data: {
                labels: ['Jan','Feb','Mar','Apr','May','Jun',
                         'Jul','Aug','Sep','Oct','Nov','Dec'],
                datasets: [{
                    label: 'Events',
                    data: [@Html.Raw(monthlyData)],
                    backgroundColor: teal,
                    borderRadius: 8, borderSkipped: false
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#f0f9fa' },
                         ticks: { color: '#6c757d', font: { size: 11 } } },
                    x: { grid: { display: false },
                         ticks: { color: '#6c757d', font: { size: 11 } } }
                }
            }
        });
    </script>
}