@model SYM_CONNECT.ViewModel.ReportViewModel
@{
    Layout = null;
    var currentYear = DateTime.Now.Year;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #2d3a3f;
            background: #fff;
            padding: 20px;
        }

        /* ── Header ── */
        .pdf-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #0ab5c4;
            padding-bottom: 10px;
            margin-bottom: 16px;
        }

            .pdf-header h1 {
                font-size: 20px;
                color: #0ab5c4;
                font-weight: bold;
            }

            .pdf-header small {
                font-size: 10px;
                color: #90adb8;
                display: block;
                margin-top: 2px;
            }

            .pdf-header .logo-area {
                text-align: right;
                font-size: 10px;
                color: #90adb8;
            }

        /* ── Summary Cards ── */
        .cards-row {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        .card-box {
            flex: 1;
            border: 1px solid #c2edf1;
            border-radius: 8px;
            padding: 10px 12px;
            background: #f0feff;
            text-align: center;
        }

            .card-box .val {
                font-size: 22px;
                font-weight: bold;
                color: #0ab5c4;
            }

            .card-box .lbl {
                font-size: 9px;
                color: #90adb8;
                text-transform: uppercase;
                margin-top: 2px;
            }

        /* ── Section Label ── */
        .section-label {
            font-size: 9px;
            font-weight: bold;
            color: #0ab5c4;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #c2edf1;
            padding-bottom: 4px;
            margin: 14px 0 8px;
        }

        /* ── Tables ── */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
            font-size: 10px;
        }

        thead tr {
            background: #0ab5c4;
            color: #fff;
        }

        thead th {
            padding: 6px 10px;
            text-align: left;
            font-weight: 600;
            font-size: 9px;
            text-transform: uppercase;
        }

        tbody tr:nth-child(even) {
            background: #f0feff;
        }

        tbody tr:nth-child(odd) {
            background: #fff;
        }

        tbody td {
            padding: 6px 10px;
            border-bottom: 1px solid #e8f8fa;
        }

        /* ── Badges ── */
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: 600;
        }

        .badge-active {
            background: #e6faf5;
            color: #0ab5c4;
            border: 1px solid #b2eaf0;
        }

        .badge-inactive {
            background: #fde8e8;
            color: #ef4444;
            border: 1px solid #fca5a5;
        }

        .badge-done {
            background: #e8eeff;
            color: #3a7bd5;
            border: 1px solid #b8d4f8;
        }

        .badge-upcoming {
            background: #fff8e6;
            color: #f39c12;
            border: 1px solid #fde8b0;
        }

        /* ── Progress Bar ── */
        .progress-track {
            background: #e8f8fa;
            border-radius: 10px;
            height: 6px;
            width: 80px;
            display: inline-block;
            vertical-align: middle;
        }

        .progress-fill {
            background: #0ab5c4;
            height: 6px;
            border-radius: 10px;
        }

        /* ── Two Column Layout ── */
        .two-col {
            display: flex;
            gap: 12px;
        }

            .two-col > div {
                flex: 1;
            }

        /* ── Footer ── */
        .pdf-footer {
            margin-top: 20px;
            border-top: 1px solid #c2edf1;
            padding-top: 8px;
            text-align: right;
            font-size: 9px;
            color: #90adb8;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="pdf-header">
        <div>
            <h1>&#9679; SYM Connect — Reports</h1>
            <small>Generated on: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")</small>
            <small>Overview of members, leaders, groups, and events</small>
        </div>
        <div class="logo-area">
            SYM Connect System<br />
            <strong>Confidential</strong>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="section-label">Summary Overview</div>
    <div class="cards-row">
        <div class="card-box">
            <div class="val">@Model.TotalMembers</div>
            <div class="lbl">Total Members</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.ActiveMembers</div>
            <div class="lbl">Active Members</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.InactiveMembers</div>
            <div class="lbl">Inactive Members</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.TotalLeaders</div>
            <div class="lbl">Leaders</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.TotalGroups</div>
            <div class="lbl">Groups</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.TotalEvents</div>
            <div class="lbl">Total Events</div>
        </div>
        <div class="card-box">
            <div class="val">@Model.DoneEvents</div>
            <div class="lbl">Done</div>
        </div>
    </div>

    <!-- Members & Groups side by side -->
    <div class="two-col">

        <!-- Members per Group -->
        <div>
            <div class="section-label">Members per Group</div>
            <table>
                <thead>
                    <tr>
                        <th>Group</th>
                        <th>Leader</th>
                        <th>Members</th>
                        <th>Fill Rate</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.Groups)
                    {
                        var count = g.GroupMembers.Count;
                        var fillPct = Model.MaxMembers > 0
                        ? (int)((count / (double)Model.MaxMembers) * 100) : 0;
                        <tr>
                            <td><strong>@g.Name</strong></td>
                            <td>@(g.Leader?.FullName ?? "—")</td>
                            <td>@count</td>
                            <td>
                                @fillPct%
                                <div class="progress-track">
                                    <div class="progress-fill"
                                         style="width:@fillPct%;"></div>
                                </div>
                            </td>
                            <td>
                                @if (g.Status == "Active")
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-inactive">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Leaders Overview -->
        <div>
            <div class="section-label">Leaders Overview</div>
            <table>
                <thead>
                    <tr>
                        <th>Leader</th>
                        <th>Group</th>
                        <th>Members</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ld in Model.LeaderData)
                    {
                        <tr>
                            <td><strong>@ld.Leader.FullName</strong></td>
                            <td>
                                @if (ld.Group != null)
                                {
                                    @ld.Group.Name
                                }
                                else
                                {
                                    <em>Unassigned</em>
                                }
                            </td>
                            <td>@(ld.Members?.ToString() ?? "—")</td>
                            <td>
                                @if (ld.Group == null)
                                {
                                    <span class="badge badge-inactive">No Group</span>
                                }
                                else if (ld.Group.Status == "Active")
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-inactive">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Events -->
    <div class="section-label">Recent Events</div>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Event Title</th>
                <th>Assigned Group</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var ev in Model.RecentEvents)
            {
                var groupName = ev.AssignedGroups.Any()
                ? string.Join(", ", ev.AssignedGroups.Select(g => g.Name))
                : "All Groups";
                var isDone = ev.EventDate < DateTime.Now;
                <tr>
                    <td>@i</td>
                    <td><strong>@ev.Title</strong></td>
                    <td>@groupName</td>
                    <td>@ev.EventDate.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (isDone)
                        {
                            <span class="badge badge-done">Done</span>
                        }
                        else
                        {
                            <span class="badge badge-upcoming">Upcoming</span>
                        }
                    </td>
                </tr>
                i++;
            }
        </tbody>
    </table>

    <!-- Events per Month -->
    <div class="section-label">Events per Month (@currentYear)</div>
    <table>
        <thead>
            <tr>
                @foreach (var m in new[]{"Jan","Feb","Mar","Apr","May","Jun",
                                                                                  "Jul","Aug","Sep","Oct","Nov","Dec"})
                {
                    <th style="text-align:center;">@m</th>
                }
            </tr>
        </thead>
        <tbody>
            <tr>
                @foreach (var count in Model.EventsPerMonth)
                {
                    <td style="text-align:center;font-weight:bold;color:#0ab5c4;">
                        @count
                    </td>
                }
            </tr>
        </tbody>
    </table>

    <!-- Footer -->
    <div class="pdf-footer">
        SYM Connect System — Confidential &nbsp;|&nbsp;
        Generated: @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")
    </div>

</body>
</html>