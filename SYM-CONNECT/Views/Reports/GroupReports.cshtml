@model SYM_CONNECT.ViewModel.GroupReportViewModel
@using SYM_CONNECT.Models
@{
    ViewData["Title"] = $"Group Report — {Model.GroupName}";
    Layout = "_Layout";

    var allGroups = ViewBag.AllGroups as List<SYMGroup> ?? new();
    int filterYear = ViewBag.SelectedYear ?? DateTime.Now.Year;

    var monthLabels = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    var eventsData = string.Join(",", Model.MonthlyEventsAttended);
    var pointsData = string.Join(",", Model.MonthlyPointsEarned);

    string rankSuffix = Model.GroupRank switch { 1 => "st", 2 => "nd", 3 => "rd", _ => "th" };
    var attPct = (int)Model.AttendanceRate;
    var attClass = attPct >= 80 ? "delta-up" : attPct >= 50 ? "delta-neu" : "delta-down";
}

<style>
    /* ── Base (inherits report theme) ──────────────────────────── */
    .gr-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 1.25rem;
    }

    .gr-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1a1a2e;
    }

        .gr-title span {
            color: #0ab5c4;
        }

    .gr-meta {
        font-size: 0.78rem;
        color: #6c757d;
        margin-top: 3px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .gr-meta b {
            color: #374151;
        }

    /* Group selector */
    .group-selector {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

        .group-selector select, .group-selector input[type=number] {
            font-size: 0.82rem;
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            background: #fff;
            color: #374151;
        }

    .btn-go {
        background: #0ab5c4;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-go:hover {
            background: #07869b;
        }

    /* Section label */
    .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #6c757d;
        margin: 1.4rem 0 .7rem;
        padding-left: 2px;
    }

    /* Stat cards */
    .stat-card {
        background: #fff;
        border-radius: 14px;
        padding: 18px 16px;
        box-shadow: 0 2px 8px rgba(10,181,196,.07);
        border: 1px solid #e8fafb;
        position: relative;
        overflow: hidden;
        transition: transform .18s,box-shadow .18s;
    }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(10,181,196,.13);
        }

    .stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        margin-bottom: 10px;
    }

    .stat-label {
        font-size: 0.7rem;
        color: #6c757d;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 2px;
    }

    .stat-value {
        font-size: 1.85rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1;
        margin-bottom: 5px;
    }

    .stat-delta {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
    }

    .delta-up {
        background: #e1f5ee;
        color: #0f6e56;
    }

    .delta-down {
        background: #fde8e8;
        color: #b91c1c;
    }

    .delta-neu {
        background: #f1f5f9;
        color: #64748b;
    }

    .stat-accent {
        position: absolute;
        bottom: -10px;
        right: -10px;
        width: 55px;
        height: 55px;
        border-radius: 50%;
        opacity: .07;
    }

    .ic-teal {
        background: #e8fafb;
        color: #0ab5c4;
    }

    .ic-green {
        background: #e1f5ee;
        color: #0f6e56;
    }

    .ic-yellow {
        background: #fef9e7;
        color: #b7800a;
    }

    .ic-blue {
        background: #e6f0fd;
        color: #185fa5;
    }

    .ic-purple {
        background: #f0eeff;
        color: #534ab7;
    }

    .ic-red {
        background: #fde8e8;
        color: #b91c1c;
    }

    /* Card table */
    .card-table {
        background: #fff;
        border-radius: 14px;
        border: 1px solid #e8fafb;
        box-shadow: 0 2px 8px rgba(10,181,196,.05);
        overflow: hidden;
    }

    .ct-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 16px;
        border-bottom: 1px solid #f0f9fa;
    }

        .ct-header h6 {
            margin: 0;
            font-size: 0.85rem;
            font-weight: 600;
            color: #1a1a2e;
        }

        .ct-header small {
            font-size: 0.72rem;
            color: #6c757d;
        }

    .icon-sm {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: #e8fafb;
        color: #0ab5c4;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.82rem;
        flex-shrink: 0;
    }

    .chart-body {
        padding: 14px 16px;
    }

    .chart-wrap {
        position: relative;
        width: 100%;
        height: 200px;
    }

    /* Tables */
    .user-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.79rem;
    }

        .user-table th {
            padding: 7px 12px;
            font-size: 0.68rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: .04em;
            background: #f8fbfc;
            border-bottom: 1px solid #e8fafb;
        }

        .user-table td {
            padding: 9px 12px;
            border-bottom: 1px solid #f0f9fa;
            color: #374151;
            vertical-align: middle;
        }

        .user-table tr:last-child td {
            border-bottom: none;
        }

        .user-table tr.highlight-row td {
            background: #f0fbfc;
        }

    .table-footer {
        padding: 7px 14px;
        font-size: 0.71rem;
        color: #6c757d;
        border-top: 1px solid #f0f9fa;
        background: #f8fbfc;
    }

    /* Badges */
    .badge-active {
        background: #e1f5ee;
        color: #0f6e56;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-inactive {
        background: #fde8e8;
        color: #b91c1c;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-done {
        background: #e8fafb;
        color: #07869b;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-upcoming {
        background: #fef9e7;
        color: #b7800a;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-warning {
        background: #fef3cd;
        color: #856404;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-flag {
        background: #fde8e8;
        color: #b91c1c;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Progress */
    .progress-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .progress-track {
        flex: 1;
        background: #e8fafb;
        border-radius: 4px;
        height: 6px;
        min-width: 60px;
    }

    .progress-fill {
        background: #0ab5c4;
        border-radius: 4px;
        height: 6px;
    }

        .progress-fill.pf-green {
            background: #1D9E75;
        }

        .progress-fill.pf-yellow {
            background: #b7800a;
        }

        .progress-fill.pf-red {
            background: #e24b4a;
        }

    /* Recognition badges */
    .badge-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 14px 16px;
    }

    .rec-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #e8fafb;
        border: 1px solid #0ab5c4;
        color: #07869b;
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 0.75rem;
        font-weight: 600;
    }

        .rec-badge i {
            font-size: 0.8rem;
            color: #0ab5c4;
        }

    .no-badges {
        font-size: 0.8rem;
        color: #6c757d;
        padding: 14px 16px;
        font-style: italic;
    }

    /* Milestone */
    .milestone-list {
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .milestone-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .milestone-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.78rem;
    }

    .milestone-label {
        color: #374151;
        font-weight: 500;
    }

    .milestone-val {
        font-size: 0.72rem;
        color: #6c757d;
    }

    .milestone-achieved {
        color: #0f6e56;
        font-weight: 600;
    }

    /* Staff notes */
    .note-list {
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .note-card {
        background: #f8fbfc;
        border-left: 3px solid #0ab5c4;
        border-radius: 0 8px 8px 0;
        padding: 10px 13px;
    }

    .note-author {
        font-size: 0.72rem;
        font-weight: 600;
        color: #0ab5c4;
        margin-bottom: 3px;
    }

    .note-date {
        font-size: 0.68rem;
        color: #9ca3af;
    }

    .note-text {
        font-size: 0.8rem;
        color: #374151;
        line-height: 1.5;
        margin-top: 4px;
    }

    .note-form {
        padding: 14px 16px;
        border-top: 1px solid #f0f9fa;
    }

        .note-form textarea {
            width: 100%;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 8px 10px;
            font-size: 0.8rem;
            color: #374151;
            resize: vertical;
            min-height: 70px;
        }

    .btn-note-add {
        margin-top: 8px;
        background: #0ab5c4;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 6px 18px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-note-add:hover {
            background: #07869b;
        }

    /* Leaderboard */
    .lb-rank {
        font-size: 0.9rem;
        font-weight: 700;
        width: 28px;
        text-align: center;
    }

        .lb-rank.rank-1 {
            color: #b7800a;
        }

        .lb-rank.rank-2 {
            color: #6c757d;
        }

        .lb-rank.rank-3 {
            color: #c04c27;
        }

    .lb-current td {
        background: #f0fbfc !important;
    }

    /* User cell */
    .user-name-cell {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .avatar-initials {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: #e8fafb;
        color: #0ab5c4;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.68rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 28px 16px;
        color: #9ca3af;
        font-size: 0.8rem;
        font-style: italic;
    }
</style>

<div class="container-fluid px-4 py-4">

    <!-- ── Page Header ──────────────────────────────────────────────── -->
    <div class="gr-header">
        <div>
            <div class="gr-title">
                <i class="bi bi-diagram-3-fill me-2" style="color:#0ab5c4;"></i>
                Group Report — <span>@Model.GroupName</span>
            </div>
            <div class="gr-meta">
                <span><i class="bi bi-geo-alt"></i> <b>@Model.Region</b> / @Model.SubRegion</span>
                <span><i class="bi bi-shield-fill-check"></i> Leader: <b>@Model.LeaderName</b></span>
                <span><i class="bi bi-calendar3"></i> Year: <b>@filterYear</b></span>
                @if (Model.Status == "Active")
                {
                    <span class="badge-active">Active</span>
                }
                else
                {

                    <span class="badge-inactive">Inactive</span>
                }
            </div>
        </div>
        <a asp-action="Index" asp-controller="Reports" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Reports
        </a>
    </div>

    <!-- ── Group + Year Selector ────────────────────────────────────── -->
    <form method="get" asp-action="GroupReport" class="group-selector">
        <select name="groupId">
            @foreach (var g in allGroups)
            {
                <option value="@g.GroupId" selected="@(g.GroupId == Model.GroupId)">@g.Name</option>
            }
        </select>
        <input type="number" name="year" value="@filterYear" min="2000" max="@DateTime.Now.Year" style="width:90px;" />
        <button type="submit" class="btn-go"><i class="bi bi-funnel-fill"></i> View</button>
    </form>

    <!-- ── Overview Stats ───────────────────────────────────────────── -->
    <div class="section-label">Overview — @Model.GroupName (@filterYear)</div>
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-teal"><i class="bi bi-people-fill"></i></div>
                <div class="stat-label">Total Members</div>
                <div class="stat-value">@Model.TotalMembers</div>
                <span class="stat-delta delta-neu">In group</span>
                <div class="stat-accent" style="background:#0ab5c4;"></div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-blue"><i class="bi bi-calendar-check-fill"></i></div>
                <div class="stat-label">Events Attended</div>
                <div class="stat-value">@Model.TotalEvents</div>
                <span class="stat-delta delta-up">This year</span>
                <div class="stat-accent" style="background:#378add;"></div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon ic-yellow"><i class="bi bi-star-fill"></i></div>
                <div class="stat-label">Total Points</div>
                <div class="stat-value">@Model.TotalPoints</div>
                <span class="stat-delta delta-up">Earned</span>
                <div class="stat-accent" style="background:#b7800a;"></div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon @(attPct >= 80 ? "ic-green" : attPct >= 50 ? "ic-yellow" : "ic-red")">
                    <i class="bi bi-bar-chart-fill"></i>
                </div>
                <div class="stat-label">Attendance Rate</div>
                <div class="stat-value">@attPct<small style="font-size:1rem;">%</small></div>
                <span class="stat-delta @attClass">
                    @(attPct >= 80 ? "Excellent" : attPct >= 50 ? "Average" : "Needs work")
                </span>
                <div class="stat-accent" style="background:#1D9E75;"></div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon @(Model.GroupRank == 1 ? "ic-yellow" : "ic-purple")">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <div class="stat-label">Group Rank</div>
                <div class="stat-value">#@Model.GroupRank</div>
                <span class="stat-delta @(Model.GroupRank == 1 ? "delta-up" : "delta-neu")">
                    @Model.GroupRank@rankSuffix of @Model.TotalGroupsCount groups
                </span>
                <div class="stat-accent" style="background:#534ab7;"></div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <div class="stat-card">
                <div class="stat-icon @(Model.NoAttendance.Count == 0 ? "ic-green" : "ic-red")">
                    <i class="bi bi-person-x-fill"></i>
                </div>
                <div class="stat-label">No Attendance</div>
                <div class="stat-value">@Model.NoAttendance.Count</div>
                @if (Model.NoAttendance.Count == 0)
                {
                    <span class="stat-delta delta-up">All engaged</span>
                }
                else
                {

                    <span class="stat-delta delta-down">Needs outreach</span>
                }
                <div class="stat-accent" style="background:#e24b4a;"></div>
            </div>
        </div>
    </div>

    <!-- ── Activity Timeline ─────────────────────────────────────────── -->
    <div class="section-label">Activity Timeline</div>
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card-table">
                <div class="ct-header">
                    <div class="icon-sm"><i class="bi bi-graph-up"></i></div>
                    <div>
                        <h6>Monthly Activity — @filterYear</h6>
                        <small>Events attended &amp; points earned per month</small>
                    </div>
                </div>
                <div class="chart-body">
                    <div class="chart-wrap" style="height:230px;">
                        <canvas id="activityChart" role="img" aria-label="Line chart of monthly events and points">Monthly activity data.</canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Member Summary ────────────────────────────────────────────── -->
    <div class="section-label">Member Summary</div>
    <div class="row g-3 mb-3">

        <!-- Top Members -->
        <div class="col-md-4">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fef9e7;color:#b7800a;"><i class="bi bi-trophy-fill"></i></div>
                    <div><h6>Most Active</h6><small>Top 5 by points</small></div>
                </div>
                <table class="user-table">
                    <thead><tr><th>#</th><th>Member</th><th>Points</th></tr></thead>
                    <tbody>
                        @if (!Model.TopMembers.Any())
                        {
                            <tr><td colspan="3" class="empty-state">No data yet</td></tr>
                        }
                        @{
                            int topRank = 1;
                        }
                        @foreach (var m in Model.TopMembers)
                        {
                            <tr>
                                <td><span class="lb-rank rank-@(topRank <= 3 ? topRank : 0)">@topRank</span></td>
                                <td>
                                    <span class="user-name-cell">
                                        <div class="avatar-initials">@(m.FullName.Length > 0 ? m.FullName[0].ToString() : "?")</div>
                                        @m.FullName
                                    </span>
                                </td>
                                <td><strong style="color:#b7800a;">@m.PointsEarned</strong></td>
                            </tr>
                            topRank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Least Active -->
        <div class="col-md-4">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fef3cd;color:#b7800a;"><i class="bi bi-exclamation-triangle-fill"></i></div>
                    <div><h6>Least Active</h6><small>Bottom 5 — needs follow-up</small></div>
                </div>
                <table class="user-table">
                    <thead><tr><th>Member</th><th>Points</th><th>Status</th></tr></thead>
                    <tbody>
                        @if (!Model.LeastActive.Any())
                        {
                            <tr><td colspan="3" class="empty-state">No data yet</td></tr>
                        }
                        @foreach (var m in Model.LeastActive)
                        {
                            <tr>
                                <td>
                                    <span class="user-name-cell">
                                        <div class="avatar-initials">@(m.FullName.Length > 0 ? m.FullName[0].ToString() : "?")</div>
                                        @m.FullName
                                    </span>
                                </td>
                                <td>@m.PointsEarned</td>
                                <td><span class="badge-warning">Follow up</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- No Attendance -->
        <div class="col-md-4">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fde8e8;color:#b91c1c;"><i class="bi bi-person-x-fill"></i></div>
                    <div><h6>No Attendance</h6><small>Flagged for outreach</small></div>
                </div>
                <table class="user-table">
                    <thead><tr><th>Member</th><th>Action</th></tr></thead>
                    <tbody>
                        @if (!Model.NoAttendance.Any())
                        {
                            <tr><td colspan="2" class="empty-state">Everyone has attended!</td></tr>
                        }
                        @foreach (var m in Model.NoAttendance)
                        {
                            <tr>
                                <td>
                                    <span class="user-name-cell">
                                        <div class="avatar-initials" style="background:#fde8e8;color:#b91c1c;">@(m.FullName.Length > 0 ? m.FullName[0].ToString() : "?")</div>
                                        @m.FullName
                                    </span>
                                </td>
                                <td><span class="badge-flag">Reach out</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Event Breakdown ───────────────────────────────────────────── -->
    <div class="section-label">Event Breakdown</div>
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card-table">
                <div class="ct-header">
                    <div class="icon-sm"><i class="bi bi-calendar-event-fill"></i></div>
                    <div><h6>Events Joined</h6><small>Attendance &amp; points per event — @filterYear</small></div>
                </div>
                <div style="overflow-x:auto;">
                    <table class="user-table">
                        <thead>
                            <tr>
                                <th><i class="bi bi-calendar-event"></i> Event</th>
                                <th><i class="bi bi-calendar3"></i> Date</th>
                                <th><i class="bi bi-people"></i> Attendees</th>
                                <th><i class="bi bi-star"></i> Points</th>
                                <th><i class="bi bi-circle-half"></i> Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.EventBreakdown.Any())
                            {
                                <tr><td colspan="5" class="empty-state">No events found for @filterYear.</td></tr>
                            }
                            @foreach (var ev in Model.EventBreakdown)
                            {
                                var isDone = ev.EventDate < DateTime.Now;
                                <tr>
                                    <td><strong>@ev.Title</strong></td>
                                    <td>@ev.EventDate.ToString("MMM d, yyyy")</td>
                                    <td>@ev.Attendees</td>
                                    <td><span style="color:#b7800a;font-weight:600;">+@ev.PointsAwarded</span></td>
                                    <td>
                                        @if (isDone)
                                        {
                                            <span class="badge-done">Done</span>
                                        }
                                        else
                                        {

                                            <span class="badge-upcoming">Upcoming</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <span>@Model.EventBreakdown.Count event(s) in @filterYear</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Recognition & Milestones ─────────────────────────────────── -->
    <div class="section-label">Recognition &amp; Milestones</div>
    <div class="row g-3 mb-3">

        <!-- Badges -->
        <div class="col-md-5">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fef9e7;color:#b7800a;"><i class="bi bi-award-fill"></i></div>
                    <div><h6>Badges Earned</h6><small>Recognition for this group</small></div>
                </div>
                @if (Model.BadgesEarned.Any())
                {
                    <div class="badge-grid">
                        @foreach (var badge in Model.BadgesEarned)
                        {
                            <span class="rec-badge"><i class="bi bi-patch-check-fill"></i> @badge</span>
                        }
                    </div>
                }
                else
                {
                    <div class="no-badges">No badges earned yet. Keep going!</div>
                }
            </div>
        </div>

        <!-- Milestones -->
        <div class="col-md-7">
            <div class="card-table h-100">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#e8fafb;color:#0ab5c4;"><i class="bi bi-flag-fill"></i></div>
                    <div><h6>Milestone Tracker</h6><small>Progress toward group goals</small></div>
                </div>
                <div class="milestone-list">
                    @foreach (var ms in Model.Milestones)
                    {
                        var pfClass = ms.Pct >= 100 ? "pf-green" : ms.Pct >= 50 ? "" : "pf-yellow";
                        <div class="milestone-item">
                            <div class="milestone-header">
                                <span class="milestone-label">@ms.Label</span>
                                <span class="@(ms.Achieved ? "milestone-achieved" : "milestone-val")">
                                    @ms.Current / @ms.Target
                                    @if (ms.Achieved)
                                    {
                                        <i class="bi bi-check-circle-fill ms-1"></i>
                                    }
                                </span>
                            </div>
                            <div class="progress-wrap">
                                <div class="progress-track">
                                    <div class="progress-fill @pfClass" style="width:@ms.Pct%;"></div>
                                </div>
                                <small style="font-size:0.68rem;color:#6c757d;min-width:30px;">@ms.Pct%</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Leaderboard ───────────────────────────────────────────────── -->
    <div class="section-label">Group Leaderboard — @filterYear</div>
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card-table">
                <div class="ct-header">
                    <div class="icon-sm" style="background:#fef9e7;color:#b7800a;"><i class="bi bi-bar-chart-steps"></i></div>
                    <div><h6>All Groups Comparison</h6><small>Ranked by total points earned</small></div>
                </div>
                <div style="overflow-x:auto;">
                    <table class="user-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Group</th>
                                <th>Leader</th>
                                <th>Members</th>
                                <th>Events</th>
                                <th>Points</th>
                                <th>Attendance</th>
                                <th>Tag</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int lbRank = 1;
                            }
                            @foreach (var lb in Model.Leaderboard)
                            {
                                var isFirst = lbRank == 1;
                                var isLast = lbRank == Model.Leaderboard.Count;
                                <tr class="@(lb.IsCurrentGroup ? "lb-current" : "")">
                                    <td>
                                        <span class="lb-rank rank-@(lbRank <= 3 ? lbRank : 0)">
                                            @if (lbRank == 1)
                                            {
                                                <i class="bi bi-trophy-fill" style="color:#b7800a;"></i>
                                            }
                                            else if (lbRank == 2)
                                            {

                                                <i class="bi bi-trophy-fill" style="color:#6c757d;"></i>
                                            }
                                            else if (lbRank == 3)
                                            {

                                                <i class="bi bi-trophy-fill" style="color:#c04c27;"></i>
                                            }
                                            else
                                            {

                                                @lbRank
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <span class="user-name-cell">
                                            <div class="avatar-initials">@(lb.GroupName.Length > 0 ? lb.GroupName[0].ToString() : "?")</div>
                                            <span>
                                                @lb.GroupName
                                                @if (lb.IsCurrentGroup)
                                                {
                                                    <span class="badge-done ms-1">Current</span>
                                                }
                                            </span>
                                        </span>
                                    </td>
                                    <td>@lb.LeaderName</td>
                                    <td>@lb.TotalMembers</td>
                                    <td>@lb.TotalEvents</td>
                                    <td><strong style="color:#b7800a;">@lb.TotalPoints</strong></td>
                                    <td>
                                        <div class="progress-wrap">
                                            <div class="progress-track" style="min-width:50px;">
                                                <div class="progress-fill @(lb.AttendanceRate >= 80 ? "pf-green" : "")" style="width:@((int)lb.AttendanceRate)%;"></div>
                                            </div>
                                            <small style="font-size:0.68rem;color:#6c757d;">@lb.AttendanceRate%</small>
                                        </div>
                                    </td>
                                    <td>
                                        @if (isFirst)
                                        {
                                            <span class="badge-active">Most active</span>
                                        }
                                        else if (isLast && Model.Leaderboard.Count > 1)
                                        {

                                            <span class="badge-flag">Needs attention</span>
                                        }
                                        else
                                        {

                                            <span class="stat-delta delta-neu" style="font-size:0.68rem;">+@lb.MonthlyGrowth/mo avg</span>
                                        }
                                    </td>
                                </tr>
                                lbRank++;
                            }
                        </tbody>
                    </table>
                </div>
                <div class="table-footer">
                    <span>
                        @Model.Leaderboard.Count group(s) total &mdash;
                        Most active: <strong>@(Model.Leaderboard.FirstOrDefault()?.GroupName ?? "—")</strong> &nbsp;|&nbsp;
                        Most points: <strong>@(Model.Leaderboard.FirstOrDefault()?.TotalPoints ?? 0)</strong>
                    </span>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const teal = '#0ab5c4', yellow = '#b7800a';

        new Chart(document.getElementById('activityChart'), {
            type: 'bar',
            data: {
                labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                datasets: [
                    {
                        label: 'Events Attended',
                        data: [@Html.Raw(eventsData)],
                        backgroundColor: teal,
                        borderRadius: 6, borderSkipped: false,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Points Earned',
                        type: 'line',
                        data: [@Html.Raw(pointsData)],
                        borderColor: yellow,
                        backgroundColor: 'rgba(183,128,10,0.08)',
                        borderWidth: 2,
                        pointBackgroundColor: yellow,
                        pointRadius: 4,
                        tension: 0.3,
                        fill: true,
                        yAxisID: 'y1'
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        labels: { color: '#6c757d', font: { size: 11 }, boxWidth: 12, padding: 16 }
                    }
                },
                scales: {
                    y:  { beginAtZero: true, grid: { color: '#f0f9fa' }, ticks: { color: '#6c757d', font: { size: 11 }, stepSize: 1 }, title: { display: true, text: 'Events', color: '#6c757d', font: { size: 10 } } },
                    y1: { beginAtZero: true, position: 'right', grid: { display: false }, ticks: { color: '#b7800a', font: { size: 11 } }, title: { display: true, text: 'Points', color: '#b7800a', font: { size: 10 } } },
                    x:  { grid: { display: false }, ticks: { color: '#6c757d', font: { size: 11 }, autoSkip: false } }
                }
            }
        });
    </script>
}
