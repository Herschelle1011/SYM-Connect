                        </td>
                    </tr>

                    <!-- Row 4 -->
                    <tr>
                        <td>
                            <span class="user-name-cell">
                                <img src="https://i.pravatar.cc/40?img=4" alt="" class="user-avatar" />
                                Louis Vladimir E. Padigos
