@model SYM_CONNECT.ViewModel.UserManagementViewModel

@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}


        <!-- Page Header -->
        <div class="mb-2">
            <h1 class="page-title">User Management</h1>
            <p class="page-subtitle">Manage your team members and their account permissions here.</p>
        </div>

        <!-- Card / Table -->
        <div class="card-table">

            <!-- Toolbar -->
            <div class="toolbar">
                <!-- Role filter -->
                <button class="btn-role-filter">
                    <i class="bi bi-people-fill"></i> Role
                    <i class="bi bi-chevron-down" style="font-size:.65rem;opacity:.6;"></i>
                </button>

                <!-- Search -->
                <div class="search-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search" id="searchInput" oninput="filterTable()" />
                </div>

                <!-- Archive outline -->
                <button class="btn-archive-outline">
                    <i class="bi bi-archive"></i> Archive
                </button>

                <!-- Export -->
                <button class="btn-export">
                    <i class="bi bi-upload"></i> Export
                </button>

                <!-- Add User -->
                <button class="btn-add-user" data-bs-toggle="modal" data-bs-target="#addUserModal">
                    <i class="bi bi-plus-circle-fill"></i> Add User
                </button>
                
            </div>

            <!-- Table -->
            <table class="user-table" id="userTable">
                <thead>
                    <tr>
                        <th><i class="bi bi-person"></i>Full Name</th>
                        <th><i class="bi bi-envelope"></i>Email</th>
                        <th><i class="bi bi-shield-check"></i>Role</th>
                        <th><i class="bi bi-circle-half"></i>Status</th>
                        <th><i class="bi bi-calendar3"></i>Joined Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
              <tbody id="tableBody">
    @foreach (var user in Model.Users)
    {
        <tr>
            <td>
                <span class="user-name-cell">
                    <img src="https://i.pravatar.cc/40" alt="" class="user-avatar" />
                    @user.FullName
                </span>
            </td>
            <td>@user.Email</td>
            <td>@user.Role</td>
            <td>
                @if (user.Status == "Active")
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </td>
            <td>@user.CreatedAt.ToString("dd MMMM yyyy, h:mm tt")</td>
            <td>
                <button class="btn-action btn-edit"><i class="bi bi-pencil"></i> Edit</button>
                <button class="btn-action btn-arc ms-1"><i class="bi bi-archive"></i> Archive</button>
            </td>
        </tr>
    }
</tbody>
</table>    
            </table>

            <!-- Footer / Pagination -->
            <div class="table-footer">
                <div class="rows-info">
                    Rows per page
                    <select>
                        <option>05</option>
                        <option>10</option>
                        <option>25</option>
                        <option>50</option>
                    </select>
                    &nbsp; 1-5 of 100 rows
                </div>

                <div class="pagination-btns">
                    <button class="pg-btn" title="First"><i class="bi bi-chevron-double-left"></i></button>
                    <button class="pg-btn" title="Prev"><i class="bi bi-chevron-left"></i></button>
                    <button class="pg-btn active">1</button>
                    <button class="pg-btn">2</button>
                    <span style="font-size:.78rem;color:#90adb8;padding:0 4px;">…</span>
                    <button class="pg-btn">100</button>
                    <button class="pg-btn" title="Next"><i class="bi bi-chevron-right"></i></button>
                    <button class="pg-btn" title="Last"><i class="bi bi-chevron-double-right"></i></button>
                </div>
            </div>




        </div><!-- /.card-table -->

        @* STORE USERS METHOD POST  *@
        <form asp-action="UserManagement" asp-controller="Home" method="post">
    @Html.AntiForgeryToken();

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px; padding:24px; border:none;">
            
            <!-- Header -->
            <div class="modal-header border-0 p-0 mb-2">
                <h5 class="modal-title fw-semibold" style="color:#00bcd4; font-size:1.3rem;">
                    <i class="bi bi-plus-circle-fill"></i> Add User
                </h5>
            </div>
            <p style="color:#888; font-size:.85rem;">Fill out the form below to add a new user to the system.</p>

            <!-- Body -->
            <div class="modal-body p-0">
                <div class="row g-3">

                <!-- Name -->
<div class="col-6">
    <input type="text" class="form-control" placeholder="First Name" asp-for="Form.FirstName" />
    <span asp-validation-for="Form.FirstName" class="text-danger" style="font-size:.75rem;"></span>
</div>
<div class="col-6">
    <input type="text" class="form-control" placeholder="Last Name" asp-for="Form.LastName" />
    <span asp-validation-for="Form.LastName" class="text-danger" style="font-size:.75rem;"></span>
</div>

<!-- Email -->
<div class="col-12">
    <input type="email" class="form-control" placeholder="Email Address" asp-for="Form.Email" />
    <span asp-validation-for="Form.Email" class="text-danger" style="font-size:.75rem;"></span>
</div>

<!-- Password -->
<div class="col-6">
    <div class="input-group">
        <input type="password" class="form-control" placeholder="Password" id="password" asp-for="Form.Password" />
        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password', this)">
            <i class="bi bi-eye"></i>
        </button>
    </div>
    <span asp-validation-for="Form.Password" class="text-danger" style="font-size:.75rem;"></span>
</div>

<!-- Confirm Password -->
<div class="col-6">
    <div class="input-group">
        <input type="password" class="form-control" placeholder="Confirm Password" id="confirmPassword" asp-for="Form.ConfirmPassword" />
        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword', this)">
            <i class="bi bi-eye"></i>
        </button>
    </div>
    <span asp-validation-for="Form.ConfirmPassword" class="text-danger" style="font-size:.75rem;"></span>
</div>

<!-- Role & Status -->
<div class="col-6">
    <select class="form-select" asp-for="Form.Role">
        <option value="" disabled selected>Role</option>
        <option>Leader</option>
        <option>Member</option>
    </select>
    <span asp-validation-for="Form.Role" class="text-danger" style="font-size:.75rem;"></span>
</div>
<div class="col-6">
    <select class="form-select" asp-for="Form.Status">
        <option value="" disabled selected>Status</option>
        <option>Active</option>
        <option>Inactive</option>
    </select>
    <span asp-validation-for="Form.Status" class="text-danger" style="font-size:.75rem;"></span>
</div>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer border-0 p-0 mt-4">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info text-white px-4">
                        Create
                    </button>
                </div>
        </div>
    </div>
</div>
      </form>

@section Scripts{
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var hasErrors = document.querySelector(".field-validation-error");

            if (hasErrors) {
                var modal = new bootstrap.Modal(document.getElementById('addUserModal'));
                modal.show();
            }

        });
    </script>
}